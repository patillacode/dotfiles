# Enable 256-color and true-color (24-bit) support in tmux
set -g default-terminal "screen-256color" # Set terminal type for 256-color support
set -ga terminal-overrides ",*256col*:Tc" # Override to enable true-color for compatible terminals

# General
set -g set-clipboard on         # Use system clipboard
set -g detach-on-destroy off    # Don't exit from tmux when closing a session
set -g escape-time 0            # Remove delay for exiting insert mode with ESC in Neovim
set -g history-limit 1000000    # Increase history size (from 2,000)
set -g mouse on                 # Enable mouse support
set -g status-interval 3        # Update the status bar every 3 seconds (default: 15 seconds)
set -g allow-passthrough on     # Allow programs in the pane to bypass tmux (e.g. for image preview)
set -g display-time 4000        # Keep status-bar messages on screen for 4s (default: 750ms)

# Set prefix key
unbind C-b              # Unbind the default prefix key
set -g prefix C-Space   # Set new prefix key to Ctrl+Space

# Refresh tmux config with r
unbind r
bind r source-file ~/.config/tmux/tmux.conf \; display-message "✓ tmux.conf reloaded"

# Split horizontally in CWD with \
unbind %
bind \\ split-window -h -c "#{pane_current_path}"

# Split vertically in CWD with -
unbind \"
bind - split-window -v -c "#{pane_current_path}"


# New window in same path
bind c new-window -c "#{pane_current_path}"

# Pane navigation — prefix+hjkl/arrows and Alt+hjkl (no prefix)
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R
bind Left  select-pane -L
bind Down  select-pane -D
bind Up    select-pane -U
bind Right select-pane -R
bind -n M-h select-pane -L
bind -n M-j select-pane -D
bind -n M-k select-pane -U
bind -n M-l select-pane -R

# Window switching — Alt+number, Alt+n/p (no prefix)
bind -n M-1 select-window -t 1
bind -n M-2 select-window -t 2
bind -n M-3 select-window -t 3
bind -n M-4 select-window -t 4
bind -n M-5 select-window -t 5
bind -n M-6 select-window -t 6
bind -n M-7 select-window -t 7
bind -n M-8 select-window -t 8
bind -n M-9 select-window -t 9
bind -n M-n next-window
bind -n M-p previous-window
bind -n M-Tab last-window

# Pane cycling — Alt+Up/Down (by index)
bind -n M-Up   select-pane -t :.+
bind -n M-Down select-pane -t :.-

# Window cycling — Alt+Shift+Left/Right and Alt+[/] (plain Alt+Left/Right
# is reserved by Ghostty for shell word-navigation)
bind -n M-S-Left  previous-window
bind -n M-S-Right next-window
bind -n M-\[      previous-window
bind -n M-\]      next-window

# Copy mode — vi-style bindings, persist selection after copy
setw -g mode-keys vi
bind -T copy-mode-vi v send-keys -X begin-selection
bind -T copy-mode-vi y send-keys -X copy-pipe-no-clear
bind -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-no-clear

# Sesh session picker popup
bind s display-popup -E -w 60% -h 50% "sesh connect \$(sesh list | fzf --prompt='session > ')"

# Cheatsheet popup (prefix + H)
bind H display-popup -E -w 40% -h 80% "glow -p ~/.config/tmux/cheatsheet.md"

# Start windows and panes at 1, not 0
set -g base-index 1
set -g pane-base-index 1
set -g renumber-windows on # Automatically renumber windows when one is closed
set -g allow-rename off   # Prevent programs from renaming windows

# tpm plugin manager
set -g @plugin 'tmux-plugins/tpm'

# List of tmux plugins
set -g @plugin 'tmux-plugins/tmux-resurrect'    # Persist tmux sessions after computer restart
set -g @plugin 'tmux-plugins/tmux-continuum'    # Automatically saves sessions every 15 minutes
set -g @plugin 'hendrikmi/tmux-cpu-mem-monitor' # CPU and memory info
set -g @plugin 'tmux-plugins/tmux-yank'         # Cross-platform clipboard
set -g @plugin 'laktak/extrakto'                # prefix+Tab: fuzzy-pick tokens from screen
set -g @plugin 'tmux-plugins/tmux-prefix-highlight' # Visual cue when prefix is active
set -g @plugin 'tmux-plugins/tmux-open'         # 'o' in copy mode opens URLs/files

set -g @yank_action 'copy-pipe-no-clear'        # Keep selection highlighted after copy

# ── Status bar — banana theme ──────────────────────────────────────
set -g status-position top
set -g status-style "bg=black,fg=white"
set -g status-left-length 40
set -g status-right-length 80

# Left: session name pill (red, matches Starship machine label)
set -g status-left "#[fg=red,bg=black]#[fg=black,bg=red,bold] #{session_name} #[fg=red,bg=black] "

# Windows: inactive dimmed, active cyan pill
set -g window-status-separator ""
set -g window-status-format "#[fg=colour8,bg=black] #I #W  "
set -g window-status-current-format "#[fg=cyan,bg=black]#[fg=black,bg=cyan,bold] #I #W #[fg=cyan,bg=black] "

# Prefix-highlight colors (banana palette)
set -g @prefix_highlight_fg 'black'
set -g @prefix_highlight_bg 'yellow'

# Right: prefix cue + git branch + hostname (red) + time (green) — matches Starship right_format
set -g status-right "#{prefix_highlight} #[fg=colour8]#(cd #{pane_current_path} && git rev-parse --abbrev-ref HEAD 2>/dev/null | sed 's/.*/  &/')  #[fg=red,bg=black] {{ .chezmoi.hostname }} #[fg=green,bg=black] %R "

# Pane borders — double lines, warm orange active, light grey inactive
set -g pane-border-lines "double"
set -g pane-border-style "bg=default,fg=colour245"
set -g pane-active-border-style "bg=default,fg=colour166"

# Per-pane title label (falls back to the running command when no title is set)
set -g pane-border-status top
set -g pane-border-format " #{?pane_title,#{pane_title},#{pane_current_command}} "

# Rename the current pane — prefix + T
bind T command-prompt -p "Pane title:" "select-pane -T '%%'"

# Dim text in inactive panes (fg only — preserves Ghostty transparency)
set -g window-style "fg=colour245"
set -g window-active-style "fg=terminal"

# Message bar
set -g message-style "bg=black,fg=cyan,bold"

# Resurrect
set -g @resurrect-capture-pane-contents 'on'

# Initialize TMUX plugin manager (keep this line at the very bottom of tmux.conf)
run '~/.tmux/plugins/tpm/tpm'
