#!/usr/bin/env bash
{{ if eq .chezmoi.hostname "totoro" -}}
SESSION="music"

tmux has-session -t "=$SESSION" 2>/dev/null && exec tmux attach-session -t "=$SESSION"

tmux new-session -d -s "$SESSION" -c "/mnt/services/music/slskd/downloads/complete"
tmux send-keys -t "$SESSION:1.1" "yazi" Enter

tmux split-window -h -t "$SESSION:1" -c "$HOME/services/music"
tmux send-keys -t "$SESSION:1.2" "c" Enter

tmux select-pane -t "$SESSION:1.1"
tmux split-window -v -t "$SESSION:1.1" -c "/mnt/media/music.bak/staged"
tmux send-keys -t "$SESSION:1.3" "python3 -m http.server 55880" Enter

tmux select-pane -t "$SESSION:1.2"
tmux split-window -v -t "$SESSION:1.2" -c "$HOME/services/music"

tmux select-pane -t "$SESSION:1.1"
tmux attach-session -t "$SESSION"
{{ else -}}
ssh totoro -t "bash \$HOME/.config/tmux/sessions/music.sh"
{{ end -}}
