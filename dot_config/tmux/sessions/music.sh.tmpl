#!/usr/bin/env bash
{{ if eq .chezmoi.hostname "totoro" -}}
SESSION="music"

tmux has-session -t "=$SESSION" 2>/dev/null && exec tmux attach-session -t "=$SESSION"

tmux new-session -d -s "$SESSION" -c "/mnt/services/music/slskd/downloads/complete"
tmux send-keys -t "$SESSION" "yazi" Enter

# Split right column (full height)
tmux split-window -h -t "$SESSION" -c "$HOME/services/music"
tmux send-keys -t "$SESSION" "c" Enter

# Split right column down → bottom-right shell
tmux split-window -v -t "$SESSION" -c "$HOME/services/music"

# Back to pane 1, split down → bottom-left python server
tmux select-pane -t "$SESSION:1.1"
tmux split-window -v -t "$SESSION:1.1" -c "/mnt/media/music.bak/staged"
tmux send-keys -t "$SESSION" "python3 -m http.server 55880" Enter

tmux select-pane -t "$SESSION:1.1"
tmux attach-session -t "$SESSION"
{{ else -}}
ssh totoro -t "bash \$HOME/.config/tmux/sessions/music.sh"
{{ end -}}
