# .bashrc — managed by chezmoi
# Machine: {{ .machine_name }} | Traits: {{ .profiles | join ", " }} | Shell: {{ .shell }}

# Source global definitions
[[ -f /etc/bashrc ]] && source /etc/bashrc

###########
# SECRETS #
###########

# Local env (not managed by chezmoi, machine-specific)
[[ -f "$HOME/.env" ]] && source "$HOME/.env"

###########
# ALIASES #
###########

{{- /* Resolve aliases: iterate traits, collect deltas, apply overrides */ -}}
{{- $aliases := list -}}
{{- range .profiles -}}
{{-   $items := index $.trait_aliases . | default list -}}
{{-   $aliases = concat $aliases $items -}}
{{- end -}}
{{- range .include_aliases }}{{ $aliases = append $aliases . }}{{ end -}}
{{- $excluded := .exclude_aliases -}}
{{- $aliases = $aliases | uniq }}
{{ range $aliases -}}
{{ if not (has . $excluded) -}}
[[ -f "$HOME/.alias/{{ . }}.sh" ]] && source "$HOME/.alias/{{ . }}.sh"
{{ end -}}
{{- end }}
{{- if has "gui" .profiles }}
[[ -f "$HOME/.alias/ghostty.sh" ]] && source "$HOME/.alias/ghostty.sh"
{{- end }}
{{- if and (has "personal" .profiles) (has "gui" .profiles) }}
[[ -f "$HOME/.alias/music.sh" ]] && source "$HOME/.alias/music.sh"
[[ -f "$HOME/.alias/tv.sh" ]] && source "$HOME/.alias/tv.sh"
[[ -f "$HOME/.alias/twitch.sh" ]] && source "$HOME/.alias/twitch.sh"
{{- end }}

###########
# Exports #
###########

export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

export HOMEBREW_NO_AUTO_UPDATE=1
export RESEND_TELEMETRY_DISABLED=1
export RTK_TELEMETRY_DISABLED=1

# local bin
export PATH="$HOME/bin:$HOME/.local/bin:$PATH"

{{ if .use_homebrew -}}
# Homebrew (Linux)
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv bash)"
{{ end -}}

##########
# Prompt #
##########

# Starship — theme selectable via chezmoi data
export STARSHIP_CONFIG="$HOME/.config/starship/{{ .starship.theme }}.toml"
eval "$(starship init {{ .shell }})"

. "$HOME/.atuin/bin/env"
[[ -f ~/.bash-preexec.sh ]] && source ~/.bash-preexec.sh
eval "$(atuin init {{ .shell }})"
