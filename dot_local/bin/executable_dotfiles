#!/usr/bin/env bash
# dotfiles — chezmoi wrapper CLI
# Usage: dotfiles <command> [args]

set -e

CHEZMOI="${CHEZMOI:-chezmoi}"
SOURCE_DIR="$($CHEZMOI source-path 2>/dev/null || echo "$HOME/dotfiles")"

usage() {
    cat <<'EOF'
dotfiles — manage your chezmoi dotfiles

Aliases: dt, dots

SYNC & DEPLOY
  sync              Pull latest changes from git and apply
  push [msg]        Commit source changes and push to remote
  apply [--dry-run] Apply configs (--dry-run to preview)
  diff              Show pending changes
  edit <file>       Edit a managed file in $EDITOR

CUSTOMIZATION
  theme             Interactive Starship theme selector (fzf)
  secrets           Inject secrets from KeePassXC into ~/.env

INFO
  status            Machine info, profiles, managed file count
  info              Active aliases, configs, tools, and settings
  utils             List available utility scripts
  doctor            Run chezmoi diagnostics

RECOVERY
  rollback          Restore a previous snapshot (fzf)

  help              Show this message
EOF
}

cmd_sync() {
    echo "Pulling latest changes..."
    git -C "$SOURCE_DIR" pull --rebase
    echo "Applying..."
    $CHEZMOI apply
    echo "Done."
}

cmd_push() {
    local msg="${1:-update dotfiles}"
    git -C "$SOURCE_DIR" add -A
    git -C "$SOURCE_DIR" commit -m "$msg" || true
    git -C "$SOURCE_DIR" push
    echo "Pushed."
}

cmd_apply() {
    if [[ "$1" == "--dry-run" ]]; then
        $CHEZMOI apply --dry-run --verbose
    else
        $CHEZMOI apply
    fi
}

cmd_diff() {
    $CHEZMOI diff
}

cmd_edit() {
    if [[ -z "$1" ]]; then
        echo "Usage: dotfiles edit <file>" >&2
        exit 1
    fi
    $CHEZMOI edit "$1"
}

cmd_theme() {
    if ! command -v fzf &>/dev/null; then
        echo "fzf is required for interactive theme selection" >&2
        exit 1
    fi

    local theme_dir
    theme_dir="$($CHEZMOI source-path)"/dot_config/starship

    local selected
    selected=$(
        find "$theme_dir" -name "*.toml" -not -name "*.tmpl" \
            | xargs -I{} basename {} .toml \
            | sort \
            | fzf \
                --prompt="Starship theme > " \
                --preview="bat --color=always --style=plain '$theme_dir/{}.toml' 2>/dev/null || cat '$theme_dir/{}.toml'" \
                --preview-window="right:60%"
    ) || exit 0

    echo "Switching to theme: $selected"

    # Update chezmoi config
    local config="$HOME/.config/chezmoi/chezmoi.toml"
    if [[ -f "$config" ]]; then
        sed -i.bak "s/theme = \".*\"/theme = \"$selected\"/" "$config" && rm -f "$config.bak"
    fi

    # Re-apply to deploy updated STARSHIP_CONFIG in .zshrc
    $CHEZMOI apply

    echo "Theme set to '$selected'. Open a new shell or run: source ~/.zshrc"
}

cmd_status() {
    echo "=== dotfiles status ==="
    echo "Source:   $SOURCE_DIR"
    echo "Machine:  $($CHEZMOI data | command grep -o '"machine_name":"[^"]*"' | cut -d'"' -f4 2>/dev/null || hostname)"
    echo "OS:       $(uname -s)"
    echo "Profiles: $($CHEZMOI data | python3 -c 'import sys,json; d=json.load(sys.stdin); print(", ".join(d.get("profiles",[])))' 2>/dev/null || echo "unknown")"
    echo "Theme:    $($CHEZMOI data | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("starship",{}).get("theme","unknown"))' 2>/dev/null || echo "unknown")"
    echo "Managed:  $($CHEZMOI managed | wc -l | tr -d ' ') files"
    echo ""
    git -C "$SOURCE_DIR" log --oneline -3 2>/dev/null && echo ""
    git -C "$SOURCE_DIR" status --short 2>/dev/null | head -10
}

cmd_info() {
    local data
    data=$($CHEZMOI data 2>/dev/null)

    local machine profile theme shell_name
    machine=$(echo "$data" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("machine_name","unknown"))' 2>/dev/null || hostname)
    profile=$(echo "$data" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("profiles",["unknown"])[-1])' 2>/dev/null || echo "unknown")
    theme=$(echo "$data" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("starship",{}).get("theme","unknown"))' 2>/dev/null || echo "unknown")
    shell_name=$(echo "$data" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("shell","unknown"))' 2>/dev/null || echo "unknown")

    local aliases configs python_tools
    aliases=$(echo "$data" | python3 -c '
import sys, json
d = json.load(sys.stdin)
profile = d.get("profiles", ["unknown"])[-1]
all_aliases = d.get("profile_aliases", {}).get(profile, [])
print("  " + "\n  ".join(all_aliases))
' 2>/dev/null || echo "  (unavailable)")

    configs=$(echo "$data" | python3 -c '
import sys, json
d = json.load(sys.stdin)
profile = d.get("profiles", ["unknown"])[-1]
all_configs = d.get("profile_configs", {}).get(profile, [])
print("  " + "\n  ".join(all_configs))
' 2>/dev/null || echo "  (unavailable)")

    python_tools=$(echo "$data" | python3 -c '
import sys, json
d = json.load(sys.stdin)
profiles = d.get("profiles", [])
pkgs = d.get("packages", {}).get("python_tools", {})
tools = []
for p in profiles:
    tools.extend(pkgs.get(p, []))
print("  " + "\n  ".join(tools) if tools else "  (none)")
' 2>/dev/null || echo "  (unavailable)")

    echo "=== dotfiles info ==="
    echo ""
    echo "Machine:  $machine"
    echo "Profile:  $profile"
    echo "Shell:    $shell_name"
    echo "Theme:    $theme"
    echo ""
    echo "Active aliases:"
    echo "$aliases"
    echo ""
    echo "Active configs:"
    echo "$configs"
    echo ""
    echo "Python tools:"
    echo "$python_tools"
    echo ""
    echo "chezmoi:  $($CHEZMOI --version 2>/dev/null | head -1)"
}

cmd_rollback() {
    local snapshot_dir="$HOME/.local/share/chezmoi-snapshots"

    if [[ ! -d "$snapshot_dir" ]]; then
        echo "No snapshots found at $snapshot_dir" >&2
        exit 1
    fi

    if ! command -v fzf &>/dev/null; then
        echo "fzf is required for interactive rollback" >&2
        echo "Available snapshots:"
        ls -1t "$snapshot_dir"
        exit 1
    fi

    local selected
    selected=$(
        ls -1t "$snapshot_dir" \
            | fzf \
                --prompt="Restore snapshot > " \
                --preview="ls '$snapshot_dir/{}/'" \
                --preview-window="right:50%"
    ) || exit 0

    local snapshot_path="$snapshot_dir/$selected"
    echo "Restoring snapshot: $selected"
    echo ""

    # Show what would change
    echo "Files in snapshot:"
    find "$snapshot_path" -type f | sed "s|$snapshot_path/||"
    echo ""

    read -r -p "Restore this snapshot? [y/N] " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        echo "Aborted."
        exit 0
    fi

    # Restore files from snapshot
    find "$snapshot_path" -type f | while read -r src; do
        local rel="${src#$snapshot_path/}"
        local dst="$HOME/$rel"
        mkdir -p "$(dirname "$dst")"
        cp "$src" "$dst"
    done

    echo "Snapshot restored. Run 'chezmoi diff' to see current state."
}

cmd_secrets() {
    local db
    db=$(chezmoi data 2>/dev/null | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("keepassxc",{}).get("database",""))' 2>/dev/null)

    if [[ -z "$db" ]]; then
        echo "Error: keepassxc.database not set in chezmoi config." >&2
        echo "Run: chezmoi edit-config" >&2
        exit 1
    fi

    if ! command -v keepassxc-cli &>/dev/null; then
        echo "Error: keepassxc-cli not found." >&2
        exit 1
    fi

    echo "Database: $db"
    echo ""

    # ── Unlock once ─────────────────────────────────────────────
    read -r -s -p "KeePassXC master password: " kp_pass
    echo ""
    echo ""

    # Verify the password works
    if ! echo "$kp_pass" | keepassxc-cli ls -q "$db" "/" &>/dev/null; then
        echo "Error: failed to unlock database." >&2
        exit 1
    fi

    # Helper: query keepassxc without re-prompting
    kp_show() { echo "$kp_pass" | keepassxc-cli show -q -a "$1" "$db" "$2" 2>/dev/null; }
    kp_ls()   { echo "$kp_pass" | keepassxc-cli ls -q "$db" "$1" 2>/dev/null; }

    # ── GitHub token ────────────────────────────────────────────
    echo "[1/2] GitHub token (Code/dotfiles/github-pat)"
    local github_token
    github_token=$(kp_show Password "Code/dotfiles/github-pat")
    if [[ -n "$github_token" ]]; then
        echo "  ✓ GITHUB_TOKEN"
    else
        echo "  ✗ not found — skipping"
    fi
    echo ""

    # ── Telegram bots ──────────────────────────────────────────
    echo "[2/2] Telegram bots (Code/dotfiles/tg-*)"
    echo "  Each entry: Password = bot token, Notes = chat definitions"
    echo ""

    local entries
    entries=$(kp_ls "Code/dotfiles/" | grep '^tg-')

    local tg_env=""
    local tg_count=0

    if [[ -z "$entries" ]]; then
        echo "  No tg-* entries found under Code/dotfiles/"
        echo ""
        echo "  To add a Telegram bot:"
        echo "    1. Create a KeePassXC entry: Code/dotfiles/tg-<name>"
        echo "    2. Set Password = bot token"
        echo "    3. In Notes, add one chat per line:"
        echo "       chat-family: -123456"
        echo "       chat-personal: 789012"
        echo "    4. Re-run 'dotfiles secrets'"
        echo ""
        echo "  To discover chat IDs: tg-send --discover <bot>"
    else
        while IFS= read -r entry; do
            local bot_name="${entry#tg-}"
            local bot_upper
            bot_upper=$(echo "$bot_name" | tr '[:lower:]' '[:upper:]')
            local path="Code/dotfiles/$entry"

            local bot_token
            bot_token=$(kp_show Password "$path")

            if [[ -z "$bot_token" ]]; then
                echo "  ✗ $bot_name — missing Password (bot token)"
                continue
            fi

            tg_env+="export TG_BOT_${bot_upper}=\"${bot_token}\"
"
            echo "  ✓ bot: $bot_name → TG_BOT_${bot_upper}"

            # Parse chat definitions from Notes field
            local notes
            notes=$(kp_show Notes "$path")

            local chat_lines
            chat_lines=$(echo "$notes" | grep -E '^chat-')

            if [[ -z "$chat_lines" ]]; then
                echo "    ⚠ no chats defined in Notes (add 'chat-<name>: <id>' lines)"
            else
                while IFS= read -r line; do
                    local chat_name chat_id chat_upper
                    chat_name=$(echo "$line" | cut -d: -f1 | sed 's/^ *//')
                    chat_name="${chat_name#chat-}"
                    chat_id=$(echo "$line" | cut -d: -f2- | sed 's/^ *//')
                    chat_upper=$(echo "$chat_name" | tr '[:lower:]' '[:upper:]')

                    if [[ -n "$chat_name" && -n "$chat_id" ]]; then
                        tg_env+="export TG_CHAT_${bot_upper}_${chat_upper}=\"${chat_id}\"
"
                        echo "    ✓ chat: $chat_name → TG_CHAT_${bot_upper}_${chat_upper}"
                        tg_count=$((tg_count + 1))
                    fi
                done <<< "$chat_lines"
            fi
        done <<< "$entries"
    fi

    echo ""

    # ── Write ~/.env ────────────────────────────────────────────
    echo "Writing ~/.env..."

    cat > "$HOME/.env" <<EOF
# ~/.env — secrets injected by 'dotfiles secrets'
# Do not edit manually; re-run 'dotfiles secrets' to refresh.
EOF

    [[ -n "$github_token" ]] && echo "export GITHUB_TOKEN=\"$github_token\"" >> "$HOME/.env"

    if [[ -n "$tg_env" ]]; then
        echo "" >> "$HOME/.env"
        echo "# Telegram channels (tg-send <name> <message>)" >> "$HOME/.env"
        echo "$tg_env" >> "$HOME/.env"
    fi

    chmod 600 "$HOME/.env"

    # ── Summary ─────────────────────────────────────────────────
    local token_count=0
    [[ -n "$github_token" ]] && token_count=1
    echo ""
    echo "Done. ~/.env updated:"
    echo "  Tokens:   $token_count"
    echo "  Channels: $tg_count"
    echo ""
    echo "Run 'source ~/.env' or open a new shell to load."
}

cmd_utils() {
    local src_bin="$SOURCE_DIR/dot_local/bin"
    echo "UTILITY SCRIPTS (~/.local/bin)"
    echo "Run any script with -h for detailed usage."
    echo ""
    for script in "$src_bin"/executable_*; do
        [ -f "$script" ] || continue
        local name
        name=$(basename "$script" | sed 's/^executable_//')
        [ "$name" = "dotfiles" ] && continue
        local desc=""
        desc=$(sed -n 's/^# *[a-zA-Z0-9_-]* — //p' "$script" 2>/dev/null | head -1)
        printf "  %-20s %s\n" "$name" "${desc:-(no description)}"
    done

    echo ""
    echo "FZF FUNCTIONS (sourced from ~/.alias/fzf.sh)"
    echo ""
    printf "  %-20s %s\n" "fbr" "switch git branch"
    printf "  %-20s %s\n" "flog" "browse git log with diff preview"
    printf "  %-20s %s\n" "fga" "stage changed files interactively"
    printf "  %-20s %s\n" "dexec [shell]" "exec into a running container"
    printf "  %-20s %s\n" "dstop" "stop containers (multi-select)"
    printf "  %-20s %s\n" "dlogs" "tail logs of a running container"
    printf "  %-20s %s\n" "drmi" "remove images (multi-select)"
    printf "  %-20s %s\n" "fkill [signal]" "kill processes (multi-select)"
    printf "  %-20s %s\n" "fcd [dir]" "cd into subdirectories with preview"
    printf "  %-20s %s\n" "fssh" "ssh into a host from ~/.ssh/config"
    printf "  %-20s %s\n" "fenv" "browse environment variable values"
    printf "  %-20s %s\n" "fedit" "edit config files"

    echo ""
    echo "SHELL FUNCTIONS (from ~/.alias/system.sh)"
    echo ""
    printf "  %-20s %s\n" "mkcd <dir>" "mkdir + cd in one step"
}

cmd_doctor() {
    $CHEZMOI doctor
}

# ─── dispatch ────────────────────────────────────────────────
case "${1:-help}" in
    sync)    cmd_sync ;;
    push)    shift; cmd_push "$@" ;;
    apply)   shift; cmd_apply "$@" ;;
    diff)    cmd_diff ;;
    edit)    shift; cmd_edit "$@" ;;
    theme)    cmd_theme ;;
    info)     cmd_info ;;
    rollback) cmd_rollback ;;
    status)   cmd_status ;;
    secrets)  cmd_secrets ;;
    utils)    cmd_utils ;;
    doctor)   cmd_doctor ;;
    help|-h|--help) usage ;;
    *)
        echo "Unknown command: $1" >&2
        echo ""
        usage
        exit 1
        ;;
esac
