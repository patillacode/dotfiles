#!/usr/bin/env bash
# dotfiles — chezmoi wrapper CLI
# Usage: dotfiles <command> [args]

set -e

CHEZMOI="${CHEZMOI:-chezmoi}"
SOURCE_DIR="$($CHEZMOI source-path 2>/dev/null || echo "$HOME/dotfiles")"

# ─── Colors ─────────────────────────────────────────────────
BOLD="\033[1m"
DIM="\033[2m"
CYAN="\033[0;36m"
GREEN="\033[0;32m"
YELLOW="\033[0;33m"
RED="\033[0;31m"
NC="\033[0m"

_header()  { echo -e "${BOLD}${CYAN}$1${NC}"; }
_section() { echo -e "\n${BOLD}$1${NC}"; }
_ok()      { echo -e "  ${GREEN}✓${NC} $1"; }
_warn()    { echo -e "  ${YELLOW}⚠${NC} $1"; }
_fail()    { echo -e "  ${RED}✗${NC} $1"; }
_item()    { printf "  ${CYAN}%-20s${NC} %s\n" "$1" "$2"; }
_dim()     { echo -e "  ${DIM}$1${NC}"; }

usage() {
    _header "dotfiles — manage your chezmoi dotfiles"
    echo -e "  ${DIM}Aliases: dt, dots${NC}"

    _section "SETUP"
    _item "setup" "Interactive configuration wizard (gum)"

    _section "SYNC & DEPLOY"
    _item "sync" "Pull latest changes from git and apply"
    _item "push [msg]" "Commit source changes and push to remote"
    _item "apply [--dry-run]" "Apply configs (--dry-run to preview)"
    _item "diff" "Show pending changes"
    _item "edit <file>" "Edit a managed file in \$EDITOR"

    _section "CUSTOMIZATION"
    _item "theme" "Interactive Starship theme selector (fzf)"
    _item "secrets" "Inject secrets from KeePassXC into ~/.env"

    _section "INFO"
    _item "status" "Machine info, profiles, managed file count"
    _item "info" "Active aliases, configs, tools, and settings"
    _item "aliases" "Show all active aliases and functions"
    _item "utils" "List all utility scripts and functions"
    _item "doctor" "Run chezmoi diagnostics"

    _section "RECOVERY"
    _item "rollback" "Restore a previous snapshot (fzf)"
    echo ""
}

cmd_sync() {
    _header "Syncing dotfiles..."
    echo ""
    echo "Pulling latest changes..."
    git -C "$SOURCE_DIR" pull --rebase
    echo ""
    echo "Applying..."
    $CHEZMOI apply
    echo ""
    _ok "Done."
}

cmd_push() {
    local msg="${1:-update dotfiles}"
    git -C "$SOURCE_DIR" add -A
    git -C "$SOURCE_DIR" commit -m "$msg" || true
    git -C "$SOURCE_DIR" push
    _ok "Pushed."
}

cmd_apply() {
    if [[ "$1" == "--dry-run" ]]; then
        $CHEZMOI apply --dry-run --verbose
    else
        $CHEZMOI apply
    fi
}

cmd_diff() {
    $CHEZMOI diff
}

cmd_edit() {
    if [[ -z "$1" ]]; then
        echo -e "${RED}Usage:${NC} dotfiles edit <file>" >&2
        exit 1
    fi
    $CHEZMOI edit "$1"
}

cmd_theme() {
    if ! command -v fzf &>/dev/null; then
        _fail "fzf is required for interactive theme selection"
        exit 1
    fi

    local theme_dir
    theme_dir="$($CHEZMOI source-path)"/dot_config/starship

    local selected
    selected=$(
        find "$theme_dir" -name "*.toml" -o -name "*.toml.tmpl" \
            | xargs -I{} basename {} \
            | sed 's/\.toml\.tmpl$//; s/\.toml$//' \
            | sort -u \
            | fzf \
                --prompt="Starship theme > " \
                --preview="bat --color=always --style=plain '$theme_dir/{}.toml' '$theme_dir/{}.toml.tmpl' 2>/dev/null || cat '$theme_dir/{}.toml' '$theme_dir/{}.toml.tmpl' 2>/dev/null" \
                --preview-window="right:60%"
    ) || exit 0

    echo "Switching to theme: $selected"

    local config="$HOME/.config/chezmoi/chezmoi.toml"
    if [[ -f "$config" ]]; then
        sed -i.bak "s/theme = \".*\"/theme = \"$selected\"/" "$config" && rm -f "$config.bak"
    fi

    $CHEZMOI apply

    _ok "Theme set to '$selected'. Open a new shell or run: source ~/.zshrc"
}

cmd_status() {
    _header "dotfiles status"
    echo ""
    echo -e "  Source:    ${CYAN}$SOURCE_DIR${NC}"
    echo -e "  Machine:   $($CHEZMOI data | command grep -o '"machine_name":"[^"]*"' | cut -d'"' -f4 2>/dev/null || hostname)"
    echo -e "  OS:        $(uname -s)"
    echo -e "  Traits:    $($CHEZMOI data | python3 -c 'import sys,json; d=json.load(sys.stdin); print(", ".join(d.get("profiles",[])))' 2>/dev/null || echo "unknown")"
    echo -e "  Theme:     $($CHEZMOI data | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("starship",{}).get("theme","unknown"))' 2>/dev/null || echo "unknown")"
    echo -e "  Managed:   $($CHEZMOI managed | wc -l | tr -d ' ') files"

    _section "Recent commits"
    git -C "$SOURCE_DIR" log --oneline -3 2>/dev/null | sed 's/^/  /'
    echo ""
    local changes
    changes=$(git -C "$SOURCE_DIR" status --short 2>/dev/null | head -10)
    if [[ -n "$changes" ]]; then
        _section "Uncommitted changes"
        echo "$changes" | sed 's/^/  /'
        echo ""
    fi
}

cmd_info() {
    local data
    data=$($CHEZMOI data 2>/dev/null)

    local machine traits theme shell_name
    machine=$(echo "$data" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("machine_name","unknown"))' 2>/dev/null || hostname)
    traits=$(echo "$data" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(", ".join(d.get("profiles",[])))' 2>/dev/null || echo "unknown")
    theme=$(echo "$data" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("starship",{}).get("theme","unknown"))' 2>/dev/null || echo "unknown")
    shell_name=$(echo "$data" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("shell","unknown"))' 2>/dev/null || echo "unknown")

    _header "dotfiles info"
    echo ""
    echo -e "  Machine:   ${CYAN}$machine${NC}"
    echo -e "  Traits:    $traits"
    echo -e "  Shell:     $shell_name"
    echo -e "  Theme:     $theme"
    echo -e "  chezmoi:   $($CHEZMOI --version 2>/dev/null | head -1)"

    _section "Active aliases"
    echo "$data" | python3 -c '
import sys, json
d = json.load(sys.stdin)
traits = d.get("profiles", [])
trait_aliases = d.get("trait_aliases", {})
includes = d.get("include_aliases", [])
excludes = set(d.get("exclude_aliases", []))
seen = set()
aliases = []
for t in traits:
    for a in trait_aliases.get(t, []):
        if a not in seen:
            seen.add(a)
            aliases.append(a)
for a in includes:
    if a not in seen:
        seen.add(a)
        aliases.append(a)
for a in aliases:
    if a not in excludes:
        print("  " + a)
' 2>/dev/null || echo "  (unavailable)"

    _section "Active configs"
    echo "$data" | python3 -c '
import sys, json
d = json.load(sys.stdin)
traits = d.get("profiles", [])
trait_configs = d.get("trait_configs", {})
includes = d.get("include_configs", [])
excludes = set(d.get("exclude_configs", []))
seen = set()
configs = []
for t in traits:
    for c in trait_configs.get(t, []):
        if c not in seen:
            seen.add(c)
            configs.append(c)
for c in includes:
    if c not in seen:
        seen.add(c)
        configs.append(c)
for c in configs:
    if c not in excludes:
        print("  " + c)
' 2>/dev/null || echo "  (unavailable)"

    _section "Python tools"
    echo "$data" | python3 -c '
import sys, json
d = json.load(sys.stdin)
traits = d.get("profiles", [])
tool_map = d.get("trait_python_tools", {})
tools = []
for t in traits:
    tools.extend(tool_map.get(t, []))
print("\n".join("  " + t for t in tools) if tools else "  (none)")
' 2>/dev/null || echo "  (unavailable)"
    echo ""
}

cmd_rollback() {
    local snapshot_dir="$HOME/.local/share/chezmoi-snapshots"

    if [[ ! -d "$snapshot_dir" ]] || [[ -z "$(ls -A "$snapshot_dir" 2>/dev/null)" ]]; then
        _fail "No snapshots found at $snapshot_dir"
        exit 1
    fi

    # Build a list with metadata for display
    local entries=""
    for snap in $(ls -1t "$snapshot_dir"); do
        local meta="$snapshot_dir/$snap/.metadata"
        if [[ -f "$meta" ]]; then
            local date commit files
            date=$(grep '^date:' "$meta" | cut -d' ' -f2-)
            commit=$(grep '^commit:' "$meta" | cut -d' ' -f2-)
            files=$(grep '^files:' "$meta" | cut -d' ' -f2-)
            entries+="$snap  ${date}  ${files} files  ${commit}"$'\n'
        else
            # Legacy snapshots without metadata
            local file_count
            file_count=$(find "$snapshot_dir/$snap" -type f | wc -l | tr -d ' ')
            entries+="$snap  (no metadata)  ${file_count} files"$'\n'
        fi
    done

    if ! command -v fzf &>/dev/null; then
        _header "Available snapshots"
        echo ""
        echo "$entries" | while IFS= read -r line; do
            [[ -n "$line" ]] && echo "  $line"
        done
        echo ""
        _warn "fzf is required for interactive rollback"
        exit 1
    fi

    _header "Select a snapshot to restore"
    echo ""

    local selected
    selected=$(
        echo "$entries" | sed '/^$/d' \
            | fzf \
                --prompt="Restore > " \
                --preview="
                    snap=\$(echo {} | awk '{print \$1}')
                    meta=\"$snapshot_dir/\$snap/.metadata\"
                    if [ -f \"\$meta\" ]; then
                        echo '── Metadata ──'
                        cat \"\$meta\"
                        echo ''
                    fi
                    echo '── Files ──'
                    find \"$snapshot_dir/\$snap\" -type f -not -name '.metadata' -not -name '.chezmoi.toml' \
                        | sed \"s|$snapshot_dir/\$snap/||\" | sort | head -40
                " \
                --preview-window="right:50%"
    ) || exit 0

    local snap_name
    snap_name=$(echo "$selected" | awk '{print $1}')
    local snapshot_path="$snapshot_dir/$snap_name"

    echo ""
    if [[ -f "$snapshot_path/.metadata" ]]; then
        _section "Snapshot details"
        sed 's/^/  /' "$snapshot_path/.metadata"
    fi

    _section "Files to restore"
    find "$snapshot_path" -type f -not -name '.metadata' -not -name '.chezmoi.toml' \
        | sed "s|$snapshot_path/||" | sort | while read -r f; do
            echo -e "  ${DIM}$f${NC}"
        done
    echo ""

    read -r -p "Restore this snapshot? [y/N] " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        echo "Aborted."
        exit 0
    fi

    echo ""
    find "$snapshot_path" -type f -not -name '.metadata' -not -name '.chezmoi.toml' | while read -r src; do
        local rel="${src#$snapshot_path/}"
        local dst="$HOME/$rel"
        mkdir -p "$(dirname "$dst")"
        cp "$src" "$dst"
    done

    _ok "Snapshot restored. Run 'chezmoi diff' to see current state."
}

cmd_secrets() {
    local db
    db=$(chezmoi data 2>/dev/null | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("keepassxc",{}).get("database",""))' 2>/dev/null)

    if [[ -z "$db" ]]; then
        _fail "keepassxc.database not set in chezmoi config."
        _dim "Run: chezmoi edit-config"
        exit 1
    fi

    if ! command -v keepassxc-cli &>/dev/null; then
        _fail "keepassxc-cli not found."
        exit 1
    fi

    _header "dotfiles secrets"
    _dim "Database: $db"
    echo ""

    # ── Unlock once ─────────────────────────────────────────────
    read -r -s -p "KeePassXC master password: " kp_pass
    echo ""
    echo ""

    if ! echo "$kp_pass" | keepassxc-cli ls -q "$db" "/" &>/dev/null; then
        _fail "Failed to unlock database."
        exit 1
    fi

    _ok "Database unlocked"
    echo ""

    kp_show() { echo "$kp_pass" | keepassxc-cli show -q -a "$1" "$db" "$2" 2>/dev/null; }
    kp_ls()   { echo "$kp_pass" | keepassxc-cli ls -q "$db" "$1" 2>/dev/null; }

    # ── GitHub token ────────────────────────────────────────────
    _section "[1/4] GitHub token"
    _dim "Entry: Code/dotfiles/github-pat"
    local github_token
    github_token=$(kp_show Password "Code/dotfiles/github-pat")
    if [[ -n "$github_token" ]]; then
        _ok "GITHUB_TOKEN"
    else
        _fail "Not found — skipping"
    fi

    # ── Forgejo token ──────────────────────────────────────────
    _section "[2/4] Forgejo token"
    _dim "Entry: Code/dotfiles/forgejo-token"
    local forgejo_token
    forgejo_token=$(kp_show Password "Code/dotfiles/forgejo-token")
    if [[ -n "$forgejo_token" ]]; then
        _ok "FORGEJO_TOKEN"
    else
        _fail "Not found — skipping"
    fi

    # ── Telegram bots ──────────────────────────────────────────
    _section "[3/4] Telegram bots"
    _dim "Scanning Code/dotfiles/tg-* entries..."
    echo ""

    local entries
    entries=$(kp_ls "Code/dotfiles/" | grep '^tg-')

    local tg_env=""
    local tg_count=0

    if [[ -z "$entries" ]]; then
        _warn "No tg-* entries found"
        echo ""
        _dim "To add a Telegram bot:"
        _dim "  1. Create KeePassXC entry: Code/dotfiles/tg-<name>"
        _dim "  2. Set Password = bot token"
        _dim "  3. In Notes, add one chat per line:"
        _dim "     chat-family: -123456"
        _dim "     chat-personal: 789012"
        _dim "  4. Re-run 'dotfiles secrets'"
        echo ""
        _dim "To discover chat IDs: tg-send --discover <bot>"
    else
        while IFS= read -r entry; do
            local bot_name="${entry#tg-}"
            local bot_upper
            bot_upper=$(echo "$bot_name" | tr '[:lower:]' '[:upper:]')
            local path="Code/dotfiles/$entry"

            local bot_token
            bot_token=$(kp_show Password "$path")

            if [[ -z "$bot_token" ]]; then
                _fail "$bot_name — missing Password (bot token)"
                continue
            fi

            tg_env+="export TG_BOT_${bot_upper}=\"${bot_token}\"
"
            _ok "bot: $bot_name → TG_BOT_${bot_upper}"

            local notes
            notes=$(kp_show Notes "$path")

            local chat_lines
            chat_lines=$(echo "$notes" | grep -E '^chat-')

            if [[ -z "$chat_lines" ]]; then
                _warn "  no chats in Notes (add 'chat-<name>: <id>' lines)"
            else
                while IFS= read -r line; do
                    local chat_name chat_id chat_upper
                    chat_name=$(echo "$line" | cut -d: -f1 | sed 's/^ *//')
                    chat_name="${chat_name#chat-}"
                    chat_id=$(echo "$line" | cut -d: -f2- | sed 's/^ *//')
                    chat_upper=$(echo "$chat_name" | tr '[:lower:]' '[:upper:]')

                    if [[ -n "$chat_name" && -n "$chat_id" ]]; then
                        tg_env+="export TG_CHAT_${bot_upper}_${chat_upper}=\"${chat_id}\"
"
                        _ok "  chat: $chat_name → TG_CHAT_${bot_upper}_${chat_upper}"
                        tg_count=$((tg_count + 1))
                    fi
                done <<< "$chat_lines"
            fi
        done <<< "$entries"
    fi

    # ── Navidrome ──────────────────────────────────────────────
    _section "[4/4] Navidrome"
    _dim "Entry: Code/dotfiles/navidrome"
    local nav_user nav_pass
    nav_user=$(kp_show UserName "Code/dotfiles/navidrome")
    nav_pass=$(kp_show Password "Code/dotfiles/navidrome")
    if [[ -n "$nav_user" && -n "$nav_pass" ]]; then
        _ok "NAVIDROME_USER / NAVIDROME_PASS"
    else
        _fail "Not found — skipping"
    fi

    # ── Write ~/.env ────────────────────────────────────────────
    _section "Writing ~/.env"

    cat > "$HOME/.env" <<EOF
# ~/.env — secrets injected by 'dotfiles secrets'
# Do not edit manually; re-run 'dotfiles secrets' to refresh.
EOF

    # GITHUB_TOKEN: standard name used by gh CLI and most tooling
    # GITHUB_PERSONAL_ACCESS_TOKEN: required by the Claude Code GitHub MCP plugin
    [[ -n "$github_token" ]] && echo "export GITHUB_TOKEN=\"$github_token\"" >> "$HOME/.env"
    [[ -n "$github_token" ]] && echo "export GITHUB_PERSONAL_ACCESS_TOKEN=\"$github_token\"" >> "$HOME/.env"
    [[ -n "$forgejo_token" ]] && echo "export FORGEJO_TOKEN=\"$forgejo_token\"" >> "$HOME/.env"
    [[ -n "$nav_user" ]] && echo "export NAVIDROME_USER=\"$nav_user\"" >> "$HOME/.env"
    [[ -n "$nav_pass" ]] && echo "export NAVIDROME_PASS=\"$nav_pass\"" >> "$HOME/.env"

    if [[ -n "$tg_env" ]]; then
        echo "" >> "$HOME/.env"
        echo "# Telegram bots (tg-send <bot> <chat> <message>)" >> "$HOME/.env"
        echo "$tg_env" >> "$HOME/.env"
    fi

    chmod 600 "$HOME/.env"

    # ── Summary ─────────────────────────────────────────────────
    local token_count=0
    [[ -n "$github_token" ]] && token_count=$((token_count + 1))
    [[ -n "$forgejo_token" ]] && token_count=$((token_count + 1))
    echo ""
    _ok "~/.env updated  —  $token_count token(s), $tg_count chat(s)"
    _dim "Run 'source ~/.env' or open a new shell to load."
    echo ""
}

cmd_utils() {
    _header "Utility scripts & functions"
    _dim "Run any script with -h for detailed usage."

    _section "SCRIPTS (~/.local/bin)"
    local src_bin="$SOURCE_DIR/dot_local/bin"
    for script in "$src_bin"/executable_*; do
        [ -f "$script" ] || continue
        local name
        name=$(basename "$script" | sed 's/^executable_//')
        [ "$name" = "dotfiles" ] && continue
        local desc=""
        desc=$(sed -n 's/^# *[a-zA-Z0-9_-]* — //p' "$script" 2>/dev/null | head -1)
        _item "$name" "${desc:-(no description)}"
    done

    _section "FZF FUNCTIONS (~/.alias/fzf.sh)"
    _item "fbr" "switch git branch"
    _item "flog" "browse git log with diff preview"
    _item "fga" "stage changed files interactively"
    _item "dexec [shell]" "exec into a running container"
    _item "dstop" "stop containers (multi-select)"
    _item "dlogs" "tail logs of a running container"
    _item "drmi" "remove images (multi-select)"
    _item "fkill [signal]" "kill processes (multi-select)"
    _item "fcd [dir]" "cd into subdirectories with preview"
    _item "fssh" "ssh into a host from ~/.ssh/config"
    _item "fenv" "browse environment variable values"
    _item "fedit" "edit config files"

    echo ""
    _dim "See also: dotfiles aliases"
    echo ""
}

cmd_aliases() {
    # Get active profile's alias list from chezmoi data
    local data active_aliases
    data=$($CHEZMOI data 2>/dev/null)
    active_aliases=$(echo "$data" | python3 -c '
import sys, json
d = json.load(sys.stdin)
traits = d.get("profiles", [])
trait_aliases = d.get("trait_aliases", {})
includes = d.get("include_aliases", [])
excludes = set(d.get("exclude_aliases", []))
seen = set()
aliases = []
for t in traits:
    for a in trait_aliases.get(t, []):
        if a not in seen:
            seen.add(a)
            aliases.append(a)
for a in includes:
    if a not in seen:
        seen.add(a)
        aliases.append(a)
for a in aliases:
    if a not in excludes:
        print(a)
' 2>/dev/null)

    local traits
    traits=$(echo "$data" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(", ".join(d.get("profiles",[])))' 2>/dev/null)

    _header "Active aliases — traits: $traits"

    while IFS= read -r alias_name; do
        local src_file="$SOURCE_DIR/dot_alias/${alias_name}.sh"
        [[ -f "$src_file" ]] || continue

        # Get description from first comment line (# name.sh — description)
        local desc
        desc=$(sed -n 's/^# *[a-zA-Z0-9_.-]* — //p' "$src_file" 2>/dev/null | head -1)

        _section "${alias_name}${desc:+ — $desc}"

        # Extract aliases: "alias name=..." lines
        grep -E '^alias ' "$src_file" 2>/dev/null | while IFS= read -r line; do
            local aname aval
            aname=$(echo "$line" | sed "s/^alias //" | cut -d= -f1)
            aval=$(echo "$line" | cut -d= -f2- | sed "s/^['\"]//;s/['\"]$//")
            # Truncate long values
            if [[ ${#aval} -gt 50 ]]; then
                aval="${aval:0:47}..."
            fi
            printf "  ${CYAN}%-22s${NC} ${DIM}%s${NC}\n" "$aname" "$aval"
        done

        # Extract functions: "name() {" or "function name()" lines
        grep -E '^[a-zA-Z_][a-zA-Z0-9_]*\(\)|^function [a-zA-Z_]' "$src_file" 2>/dev/null | while IFS= read -r line; do
            local fname
            fname=$(echo "$line" | sed 's/().*//;s/^function //;s/ {//')
            # Try to get the comment on the line before or the inline comment
            local fdesc
            fdesc=$(grep -B1 "^${fname}()\|^function ${fname}" "$src_file" 2>/dev/null | grep '^#' | sed 's/^# *//' | head -1)
            printf "  ${CYAN}%-22s${NC} ${DIM}%s${NC}\n" "$fname()" "${fdesc:-(function)}"
        done

    done <<< "$active_aliases"
    echo ""
}

cmd_setup() {
    # ── Header ────────────────────────────────────────────────
    gum style \
        --foreground 6 --border-foreground 6 \
        --border double --align center \
        --width 52 --margin "1 2" --padding "1 4" \
        "dotfiles setup" "" "Configure your environment"

    # Print a confirmed answer line (history trail)
    _ans() { printf "  ${DIM}%-12s${NC}  ${CYAN}%s${NC}\n" "$1" "$2"; }

    # ── Read current values ────────────────────────────────────
    local data; data=$($CHEZMOI data 2>/dev/null)
    local machine_name purpose gui theme git_name git_email keepassxc_db
    local shell_val font_family font_size profiles_json

    machine_name=$(echo "$data" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('machine_name',''))" 2>/dev/null)
    git_name=$(echo     "$data" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['git']['name'])" 2>/dev/null)
    git_email=$(echo    "$data" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['git']['email'])" 2>/dev/null)
    theme=$(echo        "$data" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['starship']['theme'])" 2>/dev/null)
    keepassxc_db=$(echo "$data" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('keepassxc',{}).get('database',''))" 2>/dev/null)
    shell_val=$(echo    "$data" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('shell','bash'))" 2>/dev/null)
    font_family=$(echo  "$data" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['font']['family'])" 2>/dev/null)
    font_size=$(echo    "$data" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['font']['size'])" 2>/dev/null)
    profiles_json=$(echo "$data" | python3 -c "import sys,json; d=json.load(sys.stdin); print(json.dumps(d.get('profiles',[])))" 2>/dev/null)

    purpose=$(echo "$profiles_json" | python3 -c "import sys,json; p=json.load(sys.stdin); print('work' if 'work' in p else 'personal')" 2>/dev/null)
    gui=$(echo     "$profiles_json" | python3 -c "import sys,json; p=json.load(sys.stdin); print('y' if 'gui' in p else 'n')" 2>/dev/null)

    # ── Machine ───────────────────────────────────────────────
    gum style --foreground 6 --bold --margin "1 0 0 2" "MACHINE"
    machine_name=$(gum input \
        --placeholder "machine name" --value "$machine_name" \
        --prompt "  name  › " --prompt.foreground "6" \
        --cursor.foreground "13")
    _ans "name" "$machine_name"

    if [[ "$(uname)" == "Linux" ]]; then
        shell_val=$(gum choose --selected "$shell_val" \
            --header "  shell" --header.foreground "240" \
            --cursor.foreground "13" \
            "bash" "zsh")
        _ans "shell" "$shell_val"
    fi

    # ── Purpose ───────────────────────────────────────────────
    gum style --foreground 6 --bold --margin "1 0 0 2" "PURPOSE"
    purpose=$(gum choose --selected "$purpose" \
        --header "  personal or work?" --header.foreground "240" \
        --cursor.foreground "13" \
        "personal" "work")
    _ans "purpose" "$purpose"
    gui=$(gum choose --selected "$gui" \
        --header "  has a screen / GUI?" --header.foreground "240" \
        --cursor.foreground "13" \
        "y" "n")
    _ans "gui" "$([[ "$gui" == "y" ]] && echo "yes" || echo "no")"

    # ── Appearance ────────────────────────────────────────────
    gum style --foreground 6 --bold --margin "1 0 0 2" "APPEARANCE"
    local themes_dir="$SOURCE_DIR/dot_config/starship"
    local theme_options
    theme_options=$(ls "$themes_dir"/*.toml* 2>/dev/null | xargs -n1 basename | sed 's/\.toml.*//' | sort -u)
    theme=$(echo "$theme_options" | gum choose --selected "$theme" \
        --header "  starship theme" --header.foreground "240" \
        --cursor.foreground "13")
    _ans "theme" "$theme"

    if [[ "$gui" == "y" ]]; then
        font_family=$(gum input \
            --placeholder "font family" --value "$font_family" \
            --prompt "  font  › " --prompt.foreground "6" \
            --cursor.foreground "13")
        _ans "font" "$font_family"
        font_size=$(gum input \
            --placeholder "font size" --value "$font_size" \
            --prompt "  size  › " --prompt.foreground "6" \
            --cursor.foreground "13")
        _ans "size" "$font_size"
    fi

    # ── Identity ──────────────────────────────────────────────
    gum style --foreground 6 --bold --margin "1 0 0 2" "IDENTITY"
    git_name=$(gum input \
        --placeholder "git name" --value "$git_name" \
        --prompt "  name  › " --prompt.foreground "6" \
        --cursor.foreground "13")
    _ans "git name" "$git_name"
    git_email=$(gum input \
        --placeholder "git email" --value "$git_email" \
        --prompt "  email › " --prompt.foreground "6" \
        --cursor.foreground "13")
    _ans "git email" "$git_email"

    # ── Secrets ───────────────────────────────────────────────
    gum style --foreground 6 --bold --margin "1 0 0 2" "SECRETS"
    keepassxc_db=$(gum input \
        --placeholder "path to .kdbx (leave empty to skip)" \
        --value "$keepassxc_db" \
        --prompt "  db    › " --prompt.foreground "6" \
        --cursor.foreground "13")
    _ans "keepassxc" "${keepassxc_db:-(none)}"

    # ── Summary ───────────────────────────────────────────────
    echo ""
    gum style --foreground 6 --bold --margin "0 0 0 2" "SUMMARY"
    local summary
    summary=$(printf "  %-12s %s\n" \
        "machine"   "$machine_name" \
        "shell"     "$shell_val" \
        "purpose"   "$purpose" \
        "gui"       "$([[ "$gui" == "y" ]] && echo "yes" || echo "no")" \
        "theme"     "$theme" \
        "font"      "$([[ "$gui" == "y" ]] && echo "$font_family $font_size" || echo "(headless)")" \
        "git name"  "$git_name" \
        "git email" "$git_email" \
        "keepassxc" "${keepassxc_db:-(none)}")
    gum style \
        --border rounded --border-foreground 6 \
        --margin "0 2" --padding "1 2" \
        "$summary"

    echo ""
    gum confirm "Apply these settings?" || exit 0

    # ── Write chezmoi config directly ─────────────────────────
    echo ""

    local config_file="$HOME/.config/chezmoi/chezmoi.toml"
    local os_name; os_name=$(uname -s | tr '[:upper:]' '[:lower:]')
    local profiles='["base"'
    [[ "$gui" == "y" ]] && profiles+=',"gui"'
    [[ "$purpose" == "work" ]] && profiles+=',"work"' || profiles+=',"personal"'
    profiles+=']'

    # Preserve existing per-machine include/exclude overrides
    local inc_aliases exc_aliases inc_configs exc_configs
    inc_aliases=$(echo "$data" | python3 -c "import sys,json; d=json.load(sys.stdin); print(json.dumps(d.get('include_aliases',[])))" 2>/dev/null || echo '[]')
    exc_aliases=$(echo "$data" | python3 -c "import sys,json; d=json.load(sys.stdin); print(json.dumps(d.get('exclude_aliases',[])))" 2>/dev/null || echo '[]')
    inc_configs=$(echo "$data" | python3 -c "import sys,json; d=json.load(sys.stdin); print(json.dumps(d.get('include_configs',[])))" 2>/dev/null || echo '[]')
    exc_configs=$(echo "$data" | python3 -c "import sys,json; d=json.load(sys.stdin); print(json.dumps(d.get('exclude_configs',[])))" 2>/dev/null || echo '[]')

    {
        printf 'sourceDir = "%s/dotfiles"\n\n' "$HOME"
        [[ -n "$keepassxc_db" ]] && printf '[keepassxc]\n    database = "%s"\n\n' "$keepassxc_db"
        printf '[data]\n'
        printf '    machine_name = "%s"\n' "$machine_name"
        printf '    os = "%s"\n'           "$os_name"
        printf '    shell = "%s"\n'        "$shell_val"
        printf '    use_homebrew = true\n'
        printf '    profiles = %s\n'       "$profiles"
        printf '    exclude_aliases = %s\n' "$exc_aliases"
        printf '    exclude_configs = %s\n' "$exc_configs"
        printf '    include_aliases = %s\n' "$inc_aliases"
        printf '    include_configs = %s\n' "$inc_configs"
        printf '\n    [data.font]\n'
        printf '        family = "%s"\n'   "$font_family"
        printf '        size = %s\n'       "$font_size"
        printf '\n    [data.starship]\n'
        printf '        theme = "%s"\n'    "$theme"
        printf '\n    [data.git]\n'
        printf '        name = "%s"\n'     "$git_name"
        printf '        email = "%s"\n'    "$git_email"
        printf '\n    [data.keepassxc]\n'
        printf '        database = "%s"\n' "$keepassxc_db"
    } > "$config_file"

    # ── Apply ─────────────────────────────────────────────────
    gum spin --spinner dot --title " Applying configuration…" -- $CHEZMOI apply
    echo ""
    gum style --foreground 6 --bold --margin "0 2" "✓ Done!  Run 'dotfiles status' to verify."
    echo ""
}

cmd_doctor() {
    $CHEZMOI doctor
}

# ─── dispatch ────────────────────────────────────────────────
case "${1:-help}" in
    setup)   cmd_setup ;;
    sync)    cmd_sync ;;
    push)    shift; cmd_push "$@" ;;
    apply)   shift; cmd_apply "$@" ;;
    diff)    cmd_diff ;;
    edit)    shift; cmd_edit "$@" ;;
    theme)    cmd_theme ;;
    info)     cmd_info ;;
    rollback) cmd_rollback ;;
    status)   cmd_status ;;
    secrets)  cmd_secrets ;;
    aliases)  cmd_aliases ;;
    utils)    cmd_utils ;;
    doctor)   cmd_doctor ;;
    help|-h|--help) usage ;;
    *)
        echo -e "${RED}Unknown command:${NC} $1" >&2
        echo ""
        usage
        exit 1
        ;;
esac
