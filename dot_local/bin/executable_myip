#!/bin/bash
# myip — show public and local IP addresses

# shellcheck source=/dev/null
source "${HOME}/.local/lib/tui.sh" 2>/dev/null || { echo "tui.sh not found — run: chezmoi apply" >&2; exit 1; }

usage() {
    echo "Usage: myip"
    echo ""
    echo "Show public (via ifconfig.me) and local IP addresses."
}

[[ "$1" == "-h" || "$1" == "--help" ]] && { usage; exit 0; }

_item "public" "$(curl -s ifconfig.me)"

if command -v ip &>/dev/null; then
    _item "local" "$(ip route get 1.1.1.1 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="src") print $(i+1)}')"
elif command -v ipconfig &>/dev/null; then
    _item "local" "$(ipconfig getifaddr en0 2>/dev/null || ipconfig getifaddr en1 2>/dev/null)"
fi
