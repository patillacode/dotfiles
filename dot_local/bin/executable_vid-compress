#!/bin/bash
# vid-compress — shrink a video file while keeping reasonable quality

usage() {
    echo "Usage: vid-compress <input> [output]"
    echo ""
    echo "Compress a video using h264/aac. Output defaults to <input>-compressed.<ext>"
    echo ""
    echo "Example: vid-compress recording.mov"
    echo "         vid-compress recording.mov small.mp4"
}

[[ "$1" == "-h" || "$1" == "--help" ]] && { usage; exit 0; }

if [ $# -lt 1 ]; then
    usage
    exit 1
fi

if ! command -v ffmpeg &>/dev/null; then
    echo "Error: ffmpeg is not installed." >&2
    exit 1
fi

input="$1"
output="${2:-${input%.*}-compressed.${input##*.}}"

if [ ! -f "$input" ]; then
    echo "Not found: $input" >&2
    exit 1
fi

ffmpeg -i "$input" -vcodec libx264 -crf 28 -preset medium -acodec aac -b:a 128k "$output"
echo "Saved to: $output"
