#!/bin/bash
# json-fmt — pretty-print and validate JSON

# shellcheck source=/dev/null
source "${HOME}/.local/lib/tui.sh"

usage() {
    echo "Usage: json-fmt [file]"
    echo ""
    echo "Pretty-print JSON from a file or stdin."
    echo ""
    echo "Examples: json-fmt data.json"
    echo "          curl -s api.example.com | json-fmt"
}

[[ "$1" == "-h" || "$1" == "--help" ]] && { usage; exit 0; }

if ! command -v jq &>/dev/null; then
    _fail "jq is not installed."
    exit 1
fi

if [ $# -eq 0 ]; then
    jq '.'
else
    jq '.' "$1"
fi
