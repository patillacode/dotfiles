#!/bin/bash
# tg-send — send a Telegram message via bot API

# Load secrets
[[ -f "$HOME/.env" ]] && source "$HOME/.env"

# ─── Colors ─────────────────────────────────────────────────
BOLD="\033[1m"
DIM="\033[2m"
CYAN="\033[0;36m"
GREEN="\033[0;32m"
RED="\033[0;31m"
NC="\033[0m"

usage() {
    echo -e "${BOLD}${CYAN}tg-send — send a Telegram message via bot API${NC}"
    echo ""
    echo -e "${BOLD}USAGE${NC}"
    printf "  ${CYAN}%-38s${NC} %s\n" "tg-send <bot> <chat> <message>" "Send using named bot and chat"
    printf "  ${CYAN}%-38s${NC} %s\n" "tg-send --discover <bot>" "Show recent chats the bot can see"
    printf "  ${CYAN}%-38s${NC} %s\n" "tg-send --raw <token> <id> <msg>" "Send using raw token and chat id"
    echo ""
    echo -e "${BOLD}EXAMPLES${NC}"
    echo -e "  ${DIM}tg-send dorito family 'Hello!'${NC}"
    echo -e "  ${DIM}tg-send dorito alerts 'Server is down'${NC}"
    echo -e "  ${DIM}tg-send --discover dorito${NC}"
    echo ""
    echo -e "${BOLD}SETUP${NC}"
    echo "  1. Create KeePassXC entry: Code/dotfiles/tg-<bot>"
    echo "     Password = bot token"
    echo "  2. In Notes, add chats (one per line):"
    echo -e "     ${DIM}chat-family: -123456${NC}"
    echo -e "     ${DIM}chat-personal: 789012${NC}"
    echo "  3. Run 'dotfiles secrets' to inject into ~/.env"
    echo "  4. Use 'tg-send --discover <bot>' to find chat IDs"

    # List available bots and chats from env
    local has_bots=false
    while IFS='=' read -r var _; do
        local bot="${var#TG_BOT_}"
        local bot_lower
        bot_lower=$(echo "$bot" | tr '[:upper:]' '[:lower:]')
        if ! $has_bots; then
            echo ""
            echo -e "${BOLD}AVAILABLE BOTS${NC}"
            has_bots=true
        fi
        echo -e "  ${CYAN}$bot_lower${NC}"
        env | grep "^TG_CHAT_${bot}_" | while IFS='=' read -r cvar _; do
            local chat="${cvar#TG_CHAT_${bot}_}"
            echo -e "    ${DIM}-${NC} $(echo "$chat" | tr '[:upper:]' '[:lower:]')"
        done
    done < <(env | grep '^TG_BOT_' | sort)

    if ! $has_bots; then
        echo ""
        echo -e "  ${DIM}No bots configured. Run 'dotfiles secrets' first.${NC}"
    fi
    echo ""
}

tg_send_msg() {
    local bot_token=$1
    local chat_id=$2
    local message=$3

    local response http_code
    response=$(curl -s -w "\n%{http_code}" -H 'Content-Type: application/json' \
        -d "{\"chat_id\":\"$chat_id\",\"text\":\"$message\",\"disable_notification\":false}" \
        -X POST "https://api.telegram.org/bot${bot_token}/sendMessage")
    http_code=$(echo "$response" | tail -1)

    if [[ "$http_code" == "200" ]]; then
        echo -e "${GREEN}✓${NC} Message sent."
    else
        echo -e "${RED}✗${NC} Error (HTTP $http_code):" >&2
        echo "$response" | sed '$d' >&2
        return 1
    fi
}

cmd_discover() {
    local bot_name
    bot_name=$(echo "$1" | tr '[:lower:]' '[:upper:]')
    local bot_var="TG_BOT_${bot_name}"
    local bot_token="${!bot_var}"

    if [[ -z "$bot_token" ]]; then
        echo -e "${RED}✗${NC} Bot '$1' not found. Run 'dotfiles secrets' first." >&2
        exit 1
    fi

    echo -e "${BOLD}${CYAN}Discovering chats for bot '$1'...${NC}"
    echo -e "${DIM}  Tip: send a message to the bot or add it to a group first.${NC}"
    echo ""

    local response
    response=$(curl -s "https://api.telegram.org/bot${bot_token}/getUpdates")

    if ! echo "$response" | python3 -c '
import sys, json
data = json.load(sys.stdin)
if not data.get("ok"):
    print("API error:", data.get("description", "unknown"))
    sys.exit(1)
results = data.get("result", [])
if not results:
    print("No recent updates. Send a message to the bot first.")
    sys.exit(0)
seen = {}
for r in results:
    for key in ("message", "my_chat_member", "channel_post"):
        msg = r.get(key)
        if msg and "chat" in msg:
            chat = msg["chat"]
            cid = chat["id"]
            if cid not in seen:
                name = chat.get("title") or chat.get("first_name", "")
                ctype = chat.get("type", "")
                seen[cid] = (name, ctype)
print(f"  {\"CHAT ID\":>15}  {\"TYPE\":<12} NAME")
print("  " + "-" * 45)
for cid, (name, ctype) in sorted(seen.items(), key=lambda x: x[1][0]):
    print(f"  {cid:>15}  {ctype:<12} {name}")
' 2>&1; then
        echo -e "${RED}✗${NC} Failed to parse response." >&2
        exit 1
    fi

    echo ""
    echo "Add the chat ID to the KeePassXC entry Notes as:"
    echo -e "  ${DIM}chat-<name>: <chat_id>${NC}"
    echo "Then run 'dotfiles secrets' to inject."
}

main() {
    [[ "$1" == "-h" || "$1" == "--help" || $# -eq 0 ]] && { usage; exit 0; }

    # Discover mode
    if [[ "$1" == "--discover" ]]; then
        [[ -z "$2" ]] && { echo -e "${RED}Usage:${NC} tg-send --discover <bot>" >&2; exit 1; }
        cmd_discover "$2"
        exit 0
    fi

    # Raw mode
    if [[ "$1" == "--raw" ]]; then
        shift
        [[ $# -ne 3 ]] && { echo -e "${RED}Usage:${NC} tg-send --raw <token> <chat_id> <message>" >&2; exit 1; }
        tg_send_msg "$1" "$2" "$3"
        exit 0
    fi

    # Named mode: tg-send <bot> <chat> <message>
    if [[ $# -eq 3 ]]; then
        local bot_upper chat_upper
        bot_upper=$(echo "$1" | tr '[:lower:]' '[:upper:]')
        chat_upper=$(echo "$2" | tr '[:lower:]' '[:upper:]')

        local bot_var="TG_BOT_${bot_upper}"
        local chat_var="TG_CHAT_${bot_upper}_${chat_upper}"
        local bot_token="${!bot_var}"
        local chat_id="${!chat_var}"

        if [[ -z "$bot_token" ]]; then
            echo -e "${RED}✗${NC} Bot '$1' not found." >&2
            echo -e "  ${DIM}Run 'dotfiles secrets' or 'tg-send -h' to see available bots.${NC}" >&2
            exit 1
        fi
        if [[ -z "$chat_id" ]]; then
            echo -e "${RED}✗${NC} Chat '$2' not found for bot '$1'." >&2
            echo ""
            echo "Available chats for $1:"
            env | grep "^TG_CHAT_${bot_upper}_" | while IFS='=' read -r cvar _; do
                local chat="${cvar#TG_CHAT_${bot_upper}_}"
                echo -e "  ${CYAN}-${NC} $(echo "$chat" | tr '[:upper:]' '[:lower:]')"
            done
            echo ""
            echo -e "${DIM}To discover new chats: tg-send --discover $1${NC}" >&2
            exit 1
        fi

        tg_send_msg "$bot_token" "$chat_id" "$3"
        exit 0
    fi

    echo -e "${RED}✗${NC} Expected 3 arguments: <bot> <chat> <message>" >&2
    echo -e "  ${DIM}Run 'tg-send -h' for help.${NC}" >&2
    exit 1
}

main "$@"
