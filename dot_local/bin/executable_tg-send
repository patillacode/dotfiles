#!/bin/bash
# tg-send — send a Telegram message via bot API

# Load secrets
[[ -f "$HOME/.env" ]] && source "$HOME/.env"
source "${HOME}/.local/lib/tui.sh" 2>/dev/null || { echo "tui.sh not found — run: chezmoi apply" >&2; exit 1; }

usage() {
    _header "tg-send — send a Telegram message via bot API"
    echo ""
    _section "USAGE"
    _item "tg-send <bot> <chat> <message>" "Send using named bot and chat"
    _item "tg-send --discover <bot>" "Show recent chats the bot can see"
    _item "tg-send --raw <token> <id> <msg>" "Send using raw token and chat id"
    echo ""
    _section "EXAMPLES"
    _dim "tg-send dorito family 'Hello!'"
    _dim "tg-send dorito alerts 'Server is down'"
    _dim "tg-send --discover dorito"
    echo ""
    _section "SETUP"
    echo "  1. Create KeePassXC entry: Code/dotfiles/tg-<bot>"
    echo "     Password = bot token"
    echo "  2. In Notes, add chats (one per line):"
    _dim "     chat-family: -123456"
    _dim "     chat-personal: 789012"
    echo "  3. Run 'dotfiles secrets' to inject into ~/.env"
    echo "  4. Use 'tg-send --discover <bot>' to find chat IDs"

    # List available bots and chats from env
    local has_bots=false
    while IFS='=' read -r var _; do
        local bot="${var#TG_BOT_}"
        local bot_lower
        bot_lower=$(echo "$bot" | tr '[:upper:]' '[:lower:]')
        if ! $has_bots; then
            echo ""
            _section "AVAILABLE BOTS"
            has_bots=true
        fi
        _item "$bot_lower" ""
        env | grep "^TG_CHAT_${bot}_" | while IFS='=' read -r cvar _; do
            local chat="${cvar#TG_CHAT_${bot}_}"
            _dim "  - $(echo "$chat" | tr '[:upper:]' '[:lower:]')"
        done
    done < <(env | grep '^TG_BOT_' | sort)

    if ! $has_bots; then
        echo ""
        _dim "No bots configured. Run 'dotfiles secrets' first."
    fi
    echo ""
}

tg_send_msg() {
    local bot_token=$1
    local chat_id=$2
    local message=$3

    local response http_code
    response=$(curl -s -w "\n%{http_code}" -H 'Content-Type: application/json' \
        -d "{\"chat_id\":\"$chat_id\",\"text\":\"$message\",\"disable_notification\":false}" \
        -X POST "https://api.telegram.org/bot${bot_token}/sendMessage")
    http_code=$(echo "$response" | tail -1)

    if [[ "$http_code" == "200" ]]; then
        _ok "Message sent"
    else
        _fail "Error (HTTP $http_code)"
        echo "$response" | sed '$d'
        return 1
    fi
}

cmd_discover() {
    local bot_name
    bot_name=$(echo "$1" | tr '[:lower:]' '[:upper:]')
    local bot_var="TG_BOT_${bot_name}"
    local bot_token="${!bot_var}"

    if [[ -z "$bot_token" ]]; then
        _fail "Bot '$1' not found — run 'dotfiles secrets' first"
        exit 1
    fi

    _header "Discovering chats for '$1'"
    _dim "Tip: send a message to the bot or add it to a group first"
    echo ""

    local response
    response=$(curl -s "https://api.telegram.org/bot${bot_token}/getUpdates")

    if ! echo "$response" | python3 -c '
import sys, json
data = json.load(sys.stdin)
if not data.get("ok"):
    print("API error:", data.get("description", "unknown"))
    sys.exit(1)
results = data.get("result", [])
if not results:
    print("No recent updates. Send a message to the bot first.")
    sys.exit(0)
seen = {}
for r in results:
    for key in ("message", "my_chat_member", "channel_post"):
        msg = r.get(key)
        if msg and "chat" in msg:
            chat = msg["chat"]
            cid = chat["id"]
            if cid not in seen:
                name = chat.get("title") or chat.get("first_name", "")
                ctype = chat.get("type", "")
                seen[cid] = (name, ctype)
print(f"  {\"CHAT ID\":>15}  {\"TYPE\":<12} NAME")
print("  " + "-" * 45)
for cid, (name, ctype) in sorted(seen.items(), key=lambda x: x[1][0]):
    print(f"  {cid:>15}  {ctype:<12} {name}")
' 2>&1; then
        _fail "Failed to parse response"
        exit 1
    fi

    echo ""
    _section "Next steps"
    _dim "  Add the chat ID to the KeePassXC entry Notes as:"
    _dim "    chat-<name>: <chat_id>"
    _dim "  Then run 'dotfiles secrets' to inject."
}

_interactive_mode() {
    _require_gum
    _header "tg-send"
    local mode
    mode=$(_menu "Mode" "Named (bot + chat + message)" "Discover (show recent chats)" "Raw (token + chat_id + message)")

    case "$mode" in
        "Named (bot + chat + message)")
            local bot chat message
            bot=$(_input "Bot name")
            chat=$(_input "Chat name")
            message=$(_input "Message")
            local bot_upper chat_upper
            bot_upper=$(echo "$bot" | tr '[:lower:]' '[:upper:]')
            chat_upper=$(echo "$chat" | tr '[:lower:]' '[:upper:]')
            local bot_var="TG_BOT_${bot_upper}"
            local chat_var="TG_CHAT_${bot_upper}_${chat_upper}"
            local bot_token="${!bot_var}"
            local chat_id="${!chat_var}"
            if [[ -z "$bot_token" ]]; then
                _fail "Bot '$bot' not found"
                _dim "Run 'dotfiles secrets' or 'tg-send -h' to see available bots"
                exit 1
            fi
            if [[ -z "$chat_id" ]]; then
                _fail "Chat '$chat' not found for bot '$bot'"
                exit 1
            fi
            tg_send_msg "$bot_token" "$chat_id" "$message"
            ;;
        "Discover (show recent chats)")
            local bot
            bot=$(_input "Bot name")
            cmd_discover "$bot"
            ;;
        "Raw (token + chat_id + message)")
            local token chat_id message
            token=$(_input "Bot token")
            chat_id=$(_input "Chat ID")
            message=$(_input "Message")
            tg_send_msg "$token" "$chat_id" "$message"
            ;;
    esac
}

main() {
    if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        usage
        exit 0
    fi

    if [[ $# -eq 0 ]]; then
        if [ -t 0 ]; then
            _interactive_mode
            exit 0
        else
            usage
            exit 0
        fi
    fi

    # Discover mode
    if [[ "$1" == "--discover" ]]; then
        [[ -z "$2" ]] && { _fail "Usage: tg-send --discover <bot>"; exit 1; }
        cmd_discover "$2"
        exit 0
    fi

    # Raw mode
    if [[ "$1" == "--raw" ]]; then
        shift
        [[ $# -ne 3 ]] && { _fail "Usage: tg-send --raw <token> <chat_id> <message>"; exit 1; }
        tg_send_msg "$1" "$2" "$3"
        exit 0
    fi

    # Named mode: tg-send <bot> <chat> <message>
    if [[ $# -eq 3 ]]; then
        local bot_upper chat_upper
        bot_upper=$(echo "$1" | tr '[:lower:]' '[:upper:]')
        chat_upper=$(echo "$2" | tr '[:lower:]' '[:upper:]')

        local bot_var="TG_BOT_${bot_upper}"
        local chat_var="TG_CHAT_${bot_upper}_${chat_upper}"
        local bot_token="${!bot_var}"
        local chat_id="${!chat_var}"

        if [[ -z "$bot_token" ]]; then
            _fail "Bot '$1' not found"
            _dim "Run 'dotfiles secrets' or 'tg-send -h' to see available bots"
            exit 1
        fi
        if [[ -z "$chat_id" ]]; then
            _fail "Chat '$2' not found for bot '$1'"
            echo ""
            _section "Available chats for $1"
            env | grep "^TG_CHAT_${bot_upper}_" | while IFS='=' read -r cvar _; do
                local chat="${cvar#TG_CHAT_${bot_upper}_}"
                _item "-" "$(echo "$chat" | tr '[:upper:]' '[:lower:]')"
            done
            echo ""
            _dim "To discover new chats: tg-send --discover $1"
            exit 1
        fi

        tg_send_msg "$bot_token" "$chat_id" "$3"
        exit 0
    fi

    _fail "Expected 3 arguments: <bot> <chat> <message>"
    _dim "Run 'tg-send -h' for help"
    exit 1
}

main "$@"
