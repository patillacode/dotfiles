#!/bin/bash

if [ "$#" -ne 3 ]; then
    echo "Usage: $0 input_file start_time stop_time"
    exit 1
fi

input_file="$1"
start_time="$2"
stop_time="$3"
output_file="${input_file%.*}-trimmed.${input_file##*.}"

ffmpeg -i "$input_file" -ss "$start_time" -to "$stop_time" -c copy "$output_file"

echo "Trimmed audio saved to: $output_file"
