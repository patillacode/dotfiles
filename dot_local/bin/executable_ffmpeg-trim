#!/bin/bash
# ffmpeg-trim — trim a video clip by start and end time

usage() {
    echo "Usage: ffmpeg-trim <input> <start> <end>"
    echo ""
    echo "Trim a video between two timestamps. Output: <input>-trimmed.<ext>"
    echo ""
    echo "Example: ffmpeg-trim video.mp4 00:01:30 00:02:45"
}

[[ "$1" == "-h" || "$1" == "--help" ]] && { usage; exit 0; }

if [ "$#" -ne 3 ]; then
    usage
    exit 1
fi

input_file="$1"
start_time="$2"
stop_time="$3"
output_file="${input_file%.*}-trimmed.${input_file##*.}"

ffmpeg -i "$input_file" -ss "$start_time" -to "$stop_time" -c copy "$output_file"

echo "Saved to: $output_file"
