#!/usr/bin/env bash
# cup-update — interactive TUI for selectively updating Docker images flagged by cup
# Usage: cup-update [-h]

set -euo pipefail

# ─── Colors ─────────────────────────────────────────────────
BOLD=$'\e[1m'
DIM=$'\e[2m'
CYAN=$'\e[0;36m'
BCYAN=$'\e[1;36m'
BGREEN=$'\e[1;32m'
BYELLOW=$'\e[1;33m'
BRED=$'\e[1;31m'
NC=$'\e[0m'

_header()  { echo -e "${BOLD}${BCYAN}$1${NC}"; }
_section() { echo -e "\n${BOLD}${CYAN}── $1${NC}"; }
_ok()      { echo -e "  ${BGREEN}✓${NC} $1"; }
_warn()    { echo -e "  ${BYELLOW}⚠${NC}  $1"; }
_fail()    { echo -e "  ${BRED}✗${NC} $1"; }
_item()    { printf "  ${CYAN}%-24s${NC} %s\n" "$1" "$2"; }
_dim()     { echo -e "  ${DIM}$1${NC}"; }

# ─── Temp dir ───────────────────────────────────────────────
_TMPDIR=$(mktemp -d)
trap 'rm -rf "$_TMPDIR"' EXIT

# ─── Usage ──────────────────────────────────────────────────
usage() {
    _header "cup-update — interactive Docker image updater"
    echo ""
    _dim "Fetches outdated images from cup and lets you selectively update them."
    echo ""
    _section "USAGE"
    echo "  cup-update"
    echo ""
    _section "BEHAVIOUR"
    _dim "Compose services: runs 'just update' (or docker compose pull+up) for the whole stack."
    _dim "Multiple services from the same compose dir are updated in a single run."
    _dim "Standalone containers: docker pull + docker restart."
    echo ""
    _section "NOTES"
    _dim "Requires the cup container to be running."
    _dim "Required tools: docker, gum, jq"
    echo ""
}

# ─── Guards ─────────────────────────────────────────────────
check_deps() {
    local missing=()
    for cmd in docker gum jq; do
        command -v "$cmd" &>/dev/null || missing+=("$cmd")
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        _fail "Missing required tools: ${missing[*]}"
        exit 1
    fi
}

check_cup_running() {
    if ! docker ps --filter "name=^cup$" --format "{{.Names}}" 2>/dev/null | grep -q "^cup$"; then
        _fail "cup container is not running."
        _dim "Start it with: cd ~/services/cup && just up"
        exit 1
    fi
}

# ─── Data fetching ──────────────────────────────────────────
fetch_updates() {
    local outfile="${_TMPDIR}/cup-raw.json"
    if ! gum spin --title "Checking for image updates..." -- \
            sh -c "docker exec cup /cup check -r > '${outfile}' 2>&1"; then
        _fail "Failed to query cup for updates."
        cat "${outfile}" 2>/dev/null || true
        exit 1
    fi
    jq '[.images[] | select(.result.has_update == true and .result.error == null)]' "${outfile}"
}

get_containers() {
    docker ps --format '{{json .}}' | jq -s '.'
}

enrich_image() {
    local ref="$1"
    local containers_json="$2"

    local container_id=""
    container_id=$(echo "$containers_json" | jq -r \
        --arg ref "$ref" '.[] | select(.Image == $ref) | .ID' | head -1)

    local compose_dir="" compose_service="" compose_project=""
    if [[ -n "$container_id" ]]; then
        local labels
        labels=$(docker inspect "$container_id" --format '{{json .Config.Labels}}' 2>/dev/null || echo '{}')
        compose_dir=$(echo "$labels" | jq -r '."com.docker.compose.project.working_dir" // ""')
        compose_service=$(echo "$labels" | jq -r '."com.docker.compose.service" // ""')
        compose_project=$(echo "$labels" | jq -r '."com.docker.compose.project" // ""')
    fi

    printf '%s\t%s\t%s\t%s' "$container_id" "$compose_dir" "$compose_service" "$compose_project"
}

# ─── Registry URL ────────────────────────────────────────────
registry_url() {
    local ref="$1"
    local image="${ref%%:*}"
    image="${image%%@*}"

    local host="${image%%/*}"
    if [[ "$host" == "$image" || ( "$host" != *.* && "$host" != *:* ) ]]; then
        echo "https://hub.docker.com/_/${image}"
        return
    fi

    local path="${image#*/}"
    case "$host" in
        docker.io)
            if [[ "$path" == library/* ]]; then
                echo "https://hub.docker.com/_/${path#library/}"
            else
                echo "https://hub.docker.com/r/${path}"
            fi
            ;;
        *)
            echo "https://${host}/${path}"
            ;;
    esac
}

# ─── Row formatting ──────────────────────────────────────────
# printf '%-Ns' counts bytes, not display chars. _padr compensates by
# inflating the width field by the extra bytes in multi-byte UTF-8 strings.
_padr() {
    local str="$1" width="$2"
    local byte_len disp_len
    byte_len=$(printf '%s' "$str" | wc -c)
    disp_len=$(printf '%s' "$str" | wc -m)
    printf "%-$(( width + byte_len - disp_len ))s" "$str"
}

format_row() {
    local ref="$1" update_type="$2" version_bump="$3"
    local current_ver="$4" new_ver="$5"
    local compose_service="$6" compose_project="$7"

    local version_col
    if [[ "$update_type" == "version" ]]; then
        if [[ -n "$current_ver" && -n "$new_ver" ]]; then
            version_col="${current_ver} → ${new_ver}"
            [[ -n "$version_bump" ]] && version_col+=" (${version_bump})"
        elif [[ -n "$version_bump" ]]; then
            version_col="version update (${version_bump})"
        else
            version_col="version update"
        fi
    else
        version_col="digest update"
    fi

    local mgmt_col
    if [[ -n "$compose_service" ]]; then
        mgmt_col="[${compose_project}/${compose_service}]"
    else
        mgmt_col="[standalone]"
    fi

    [[ ${#ref}         -gt 42 ]] && ref="${ref:0:41}…"
    [[ ${#version_col} -gt 24 ]] && version_col="${version_col:0:23}…"

    printf '%s │ %s │ %s' \
        "$(_padr "$ref" 42)" \
        "$(_padr "$version_col" 24)" \
        "$mgmt_col"
}

# ─── Colored version info ────────────────────────────────────
format_version_colored() {
    local update_type="$1" version_bump="$2" current_ver="$3" new_ver="$4"

    if [[ "$update_type" == "version" ]]; then
        local bump_color="$NC"
        case "$version_bump" in
            major) bump_color="$BRED"    ;;
            minor) bump_color="$BYELLOW" ;;
            patch) bump_color="$BGREEN"  ;;
        esac
        if [[ -n "$current_ver" && -n "$new_ver" ]]; then
            echo -e "${DIM}${current_ver}${NC} ${CYAN}→${NC} ${BOLD}${new_ver}${NC}  ${bump_color}(${version_bump})${NC}"
        elif [[ -n "$version_bump" ]]; then
            echo -e "${bump_color}version update (${version_bump})${NC}"
        else
            echo -e "${CYAN}version update${NC}"
        fi
    else
        echo -e "${DIM}digest update${NC}"
    fi
}

# ─── Update actions ─────────────────────────────────────────
do_update_compose() {
    local compose_dir="$1"
    local label="${compose_dir##*/}"
    if [[ -f "${compose_dir}/justfile" ]]; then
        gum spin --title "Updating ${label}..." -- \
            bash -c "cd '${compose_dir}' && just update"
    else
        gum spin --title "Pulling ${label}..." -- \
            docker compose --project-directory "${compose_dir}" pull
        gum spin --title "Recreating ${label}..." -- \
            docker compose --project-directory "${compose_dir}" up -d
    fi
    _ok "Updated ${label}"
}

do_update_standalone() {
    local ref="$1" container_id="$2" in_use="$3"
    gum spin --title "Pulling ${ref}..." -- docker pull "$ref"
    if [[ "$in_use" == "true" && -n "$container_id" ]]; then
        gum spin --title "Restarting container..." -- docker restart "$container_id"
        _ok "Pulled and restarted"
    else
        _ok "Pulled  ${DIM}(container not running, restart skipped)${NC}"
    fi
}

# ─── Main ───────────────────────────────────────────────────
main() {
    for arg in "$@"; do
        case "$arg" in
            -h|--help) usage; exit 0 ;;
            *) _fail "Unknown option: ${arg}"; echo ""; usage; exit 1 ;;
        esac
    done

    check_deps
    check_cup_running

    echo ""
    _header " cup-update"
    echo ""

    local updates_json
    updates_json=$(fetch_updates)

    local count
    count=$(echo "$updates_json" | jq 'length')

    if [[ "$count" -eq 0 ]]; then
        echo ""
        gum style --border rounded --padding "0 2" --foreground 2 \
            "✓  All images are up to date."
        echo ""
        exit 0
    fi

    local containers_json
    containers_json=$(get_containers)

    declare -a rows=()
    declare -a refs=()
    declare -a cont_ids=()
    declare -a comp_dirs=()
    declare -a comp_svcs=()
    declare -a in_uses=()
    declare -a update_types=()
    declare -a version_bumps=()
    declare -a current_vers=()
    declare -a new_vers=()

    while IFS= read -r img_json; do
        local ref update_type version_bump current_ver new_ver in_use
        ref=$(echo "$img_json" | jq -r '.reference')
        update_type=$(echo "$img_json" | jq -r '.result.info.type // "digest"')
        version_bump=$(echo "$img_json" | jq -r '.result.info.version_update_type // ""')
        current_ver=$(echo "$img_json" | jq -r '.result.info.current_version // ""')
        new_ver=$(echo "$img_json" | jq -r '.result.info.new_version // .result.info.new_tag // ""')
        in_use=$(echo "$img_json" | jq -r '.in_use | tostring')

        local enriched container_id compose_dir compose_svc compose_proj
        enriched=$(enrich_image "$ref" "$containers_json")
        IFS=$'\t' read -r container_id compose_dir compose_svc compose_proj <<< "$enriched"

        local row
        row=$(format_row "$ref" "$update_type" "$version_bump" "$current_ver" "$new_ver" \
            "$compose_svc" "$compose_proj")

        rows+=("$row")
        refs+=("$ref")
        cont_ids+=("$container_id")
        comp_dirs+=("$compose_dir")
        comp_svcs+=("$compose_svc")
        in_uses+=("$in_use")
        update_types+=("$update_type")
        version_bumps+=("$version_bump")
        current_vers+=("$current_ver")
        new_vers+=("$new_ver")
    done < <(echo "$updates_json" | jq -c '.[]')

    echo ""
    gum style --border normal --padding "0 1" --foreground 3 \
        "  ${count} image update(s) available"
    echo ""

    # Step 1: multi-select images
    local selected=""
    selected=$(printf '%s\n' "${rows[@]}" | \
        gum choose --no-limit \
            --header "Select images to update  [space = toggle  enter = confirm  ctrl+a = all]" \
            --height 20) || true

    if [[ -z "$selected" ]]; then
        _dim "Nothing selected. Exiting."
        exit 0
    fi

    echo ""

    # Step 2: resolve indices
    declare -a sel_idx=()
    while IFS= read -r row; do
        local idx=-1
        for i in "${!rows[@]}"; do
            [[ "${rows[$i]}" == "$row" ]] && idx=$i && break
        done
        sel_idx+=("$idx")
    done <<< "$selected"

    # Step 3: group selected into compose stacks and standalones
    declare -A seen_compose_dirs=()
    declare -a compose_dir_list=()
    declare -a standalone_idxs=()

    for idx in "${sel_idx[@]}"; do
        [[ $idx -eq -1 ]] && continue
        if [[ -n "${comp_dirs[$idx]}" ]]; then
            if [[ -z "${seen_compose_dirs[${comp_dirs[$idx]}]+x}" ]]; then
                seen_compose_dirs["${comp_dirs[$idx]}"]=1
                compose_dir_list+=("${comp_dirs[$idx]}")
            fi
        else
            standalone_idxs+=("$idx")
        fi
    done

    # Step 4: confirmation dashboard
    echo ""
    echo -e "${BOLD}${CYAN}┌─ Review ─────────────────────────────────────────────────────────────┐${NC}"
    echo -e "${BOLD}${CYAN}│${NC}"

    for dir in "${compose_dir_list[@]}"; do
        local label="${dir##*/}"
        local cmd_preview
        if [[ -f "${dir}/justfile" ]]; then
            cmd_preview="just update  (in ${dir})"
        else
            cmd_preview="docker compose pull && up -d  (in ${dir})"
        fi

        echo -e "${BOLD}${CYAN}│${NC}  ${BOLD}${BYELLOW}${label}${NC}  ${DIM}(compose stack)${NC}"
        echo -e "${BOLD}${CYAN}│${NC}    ${DIM}\$${NC} ${CYAN}${cmd_preview}${NC}"

        for idx in "${sel_idx[@]}"; do
            [[ $idx -eq -1 ]] && continue
            [[ "${comp_dirs[$idx]}" != "$dir" ]] && continue

            local ref="${refs[$idx]}"
            local ver_info
            ver_info=$(format_version_colored \
                "${update_types[$idx]}" "${version_bumps[$idx]}" \
                "${current_vers[$idx]}" "${new_vers[$idx]}")
            local url
            url=$(registry_url "$ref")

            echo -e "${BOLD}${CYAN}│${NC}      ${BCYAN}${comp_svcs[$idx]}${NC}  ${DIM}(${ref})${NC}"
            echo -e "${BOLD}${CYAN}│${NC}        ${ver_info}"
            echo -e "${BOLD}${CYAN}│${NC}        ${DIM}↗ ${url}${NC}"
        done
        echo -e "${BOLD}${CYAN}│${NC}"
    done

    for idx in "${standalone_idxs[@]}"; do
        local ref="${refs[$idx]}"
        local ver_info
        ver_info=$(format_version_colored \
            "${update_types[$idx]}" "${version_bumps[$idx]}" \
            "${current_vers[$idx]}" "${new_vers[$idx]}")
        local url
        url=$(registry_url "$ref")

        echo -e "${BOLD}${CYAN}│${NC}  ${BOLD}${BYELLOW}${ref}${NC}  ${DIM}(standalone)${NC}"
        echo -e "${BOLD}${CYAN}│${NC}    ${ver_info}"
        echo -e "${BOLD}${CYAN}│${NC}    ${DIM}↗ ${url}${NC}"
        echo -e "${BOLD}${CYAN}│${NC}    ${DIM}\$${NC} ${CYAN}docker pull ${ref}${NC}"
        if [[ "${in_uses[$idx]}" == "true" && -n "${cont_ids[$idx]}" ]]; then
            echo -e "${BOLD}${CYAN}│${NC}    ${DIM}\$${NC} ${CYAN}docker restart ${cont_ids[$idx]}${NC}"
        fi
        echo -e "${BOLD}${CYAN}│${NC}"
    done

    echo -e "${BOLD}${CYAN}└──────────────────────────────────────────────────────────────────────┘${NC}"
    echo ""

    gum confirm "Proceed?" || { echo ""; _dim "Aborted."; exit 0; }
    echo ""

    # Step 5: execute
    local errors=0

    for dir in "${compose_dir_list[@]}"; do
        local label="${dir##*/}"
        echo -e "\n${BOLD}${CYAN}▶${NC} ${BCYAN}${label}${NC}  ${DIM}(compose stack)${NC}"
        do_update_compose "$dir" \
            || { _fail "Failed: ${label}"; errors=$((errors + 1)); }
    done

    for idx in "${standalone_idxs[@]}"; do
        echo -e "\n${BOLD}${CYAN}▶${NC} ${BCYAN}${refs[$idx]}${NC}  ${DIM}(standalone)${NC}"
        do_update_standalone "${refs[$idx]}" "${cont_ids[$idx]}" "${in_uses[$idx]}" \
            || { _fail "Failed: ${refs[$idx]}"; errors=$((errors + 1)); }
    done

    echo ""
    if [[ $errors -eq 0 ]]; then
        gum style --border rounded --padding "0 2" --foreground 2 \
            "✓  Done! All selected images updated successfully."
    else
        gum style --border rounded --padding "0 2" --foreground 1 \
            "✗  ${errors} update(s) failed. Check output above."
    fi
    echo ""
}

main "$@"
