#!/bin/bash
# git-clean-branches — delete merged local branches

source "${HOME}/.local/lib/tui.sh" 2>/dev/null || { echo "tui.sh not found — run: chezmoi apply" >&2; exit 1; }
_require_gum

usage() {
    echo "Usage: git-clean-branches"
    echo ""
    echo "Delete all local branches except protected ones"
    echo "(main, master, develop, dev, staging, production, prod)."
}

[[ "$1" == "-h" || "$1" == "--help" ]] && { usage; exit 0; }

non_removeable_branches=("develop" "dev" "master" "main" "staging" "stage" "production" "prod")

deletable=()
for branch in $(git branch | awk '{print $NF}'); do
    skip=false
    for protected in "${non_removeable_branches[@]}"; do
        [[ "$branch" == "$protected" ]] && skip=true && break
    done
    $skip || deletable+=("$branch")
done

if [[ ${#deletable[@]} -eq 0 ]]; then
    _ok "No branches to delete"
    exit 0
fi

_header "Clean git branches"

selected=$(gum choose --no-limit --header="Select branches to delete (space to select, enter to confirm)" "${deletable[@]}")

if [[ -z "$selected" ]]; then
    _dim "Aborted."
    exit 0
fi

mapfile -t selected_arr <<< "$selected"

if ! _confirm "Delete ${#selected_arr[@]} branch(es)?"; then
    _dim "Aborted."
    exit 0
fi

while IFS= read -r branch; do
    [ -z "$branch" ] && continue
    git branch -D "$branch" && _ok "Deleted: $branch" || _fail "Failed to delete: $branch"
done <<< "$selected"

_ok "Done"
