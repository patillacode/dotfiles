#! /bin/bash

RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Define the non_removeable_branches array
non_removeable_branches=("develop" "dev" "master" "main" "staging" "stage" "production" "prod")

# Get the list of local branches
local_branches=$(git branch | awk '{print $NF}')

echo -e "\n${CYAN}Cleaning up your git branches...${NC}"

# Check if each local branch is in non_removeable_branches array
for branch in $local_branches; do
  found=false
  for non_removeable_branch in "${non_removeable_branches[@]}"; do
    if [ "$branch" == "$non_removeable_branch" ]; then
      found=true
      break
    fi
  done
  if $found; then
    echo -e "${YELLOW}Skipping $branch branch...${NC}"
  else
    echo -e "${RED}Deleting $branch branch...${NC}"
    git branch -D $branch
  fi
done

echo -e "${CYAN}Deleted all non-important branches!${NC}\n"
