#!/bin/bash

# download-urls.sh
# Script to download URLs from a file using yt-dlp with random delays between downloads
# Usage: ./download-urls.sh /path/to/urls.txt [username] [password]

# Check if at least a file was provided as an argument
if [ $# -lt 1 ]; then
    echo "Usage: $0 /path/to/urls.txt [username] [password]"
    exit 1
fi

URL_FILE="$1"
USERNAME="$2"
PASSWORD="$3"

# Check if the file exists
if [ ! -f "$URL_FILE" ]; then
    echo "Error: File '$URL_FILE' not found!"
    exit 1
fi

# Check if yt-dlp is installed
if ! command -v yt-dlp &> /dev/null; then
    echo "Error: yt-dlp is not installed or not in your PATH"
    exit 1
fi

# Main process
echo "Starting download process using URLs from $URL_FILE"
echo "Press Ctrl+C to stop the process at any time"

# Count total non-empty lines in the file
total_urls=$(grep -c -v "^\s*$" "$URL_FILE")
current_url=0

# Read the file line by line
while IFS= read -r url || [ -n "$url" ]; do
    # Skip empty lines
    if [ -z "$url" ]; then
        continue
    fi

    # Increment counter
    ((current_url++))

    # Trim whitespace
    url=$(echo "$url" | xargs)

    echo "$(date '+%Y-%m-%d %H:%M:%S') - Processing URL ($current_url/$total_urls): $url"

    # Run yt-dlp with credentials if provided
    if [ -n "$USERNAME" ] && [ -n "$PASSWORD" ]; then
        yt-dlp --username "$USERNAME" --password "$PASSWORD" "$url"
    else
        yt-dlp "$url"
    fi

    # Check if this is not the last URL
    if [ "$current_url" -lt "$total_urls" ]; then
        # Generate random delay between 1-5 minutes (60-300 seconds)
        delay=$((RANDOM % 240 + 60))
        minutes=$((delay / 60))
        seconds=$((delay % 60))

        echo "$(date '+%Y-%m-%d %H:%M:%S') - Download completed. Waiting for $minutes minutes and $seconds seconds before next URL..."
        sleep $delay
    fi

done < "$URL_FILE"

echo "$(date '+%Y-%m-%d %H:%M:%S') - All downloads completed!"
