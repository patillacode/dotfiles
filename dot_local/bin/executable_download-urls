#!/bin/bash
# download-urls — batch download URLs with yt-dlp

source "${HOME}/.local/lib/tui.sh" 2>/dev/null || { echo "tui.sh not found — run: chezmoi apply" >&2; exit 1; }

usage() {
    echo "Usage: download-urls <urls.txt> [username] [password]"
    echo ""
    echo "Download each URL in the file using yt-dlp, with random"
    echo "delays (1-5 min) between downloads."
    echo ""
    echo "Example: download-urls playlist.txt"
    echo "         download-urls list.txt user pass123"
}

[[ "$1" == "-h" || "$1" == "--help" ]] && { usage; exit 0; }

if [ $# -lt 1 ]; then
    if [ -t 0 ]; then
        _require_gum
        URL_FILE=$(_input "URL file path")
        [ -z "$URL_FILE" ] && { usage; exit 1; }
    else
        usage
        exit 1
    fi
else
    URL_FILE="$1"
fi

USERNAME="${2:-}"
PASSWORD="${3:-}"

if [ ! -f "$URL_FILE" ]; then
    _fail "File '$URL_FILE' not found!"
    exit 1
fi

if ! command -v yt-dlp &>/dev/null; then
    _fail "yt-dlp is not installed."
    exit 1
fi

_header "Batch Download"
_dim "URLs from $URL_FILE — press Ctrl+C to stop"

total_urls=$(grep -c -v "^\s*$" "$URL_FILE")
current_url=0

while IFS= read -r url || [ -n "$url" ]; do
    [ -z "$url" ] && continue
    ((current_url++))
    url=$(echo "$url" | xargs)

    _item "[$current_url/$total_urls]" "$url"

    if [ -n "$USERNAME" ] && [ -n "$PASSWORD" ]; then
        yt-dlp --username "$USERNAME" --password "$PASSWORD" "$url"
    else
        yt-dlp "$url"
    fi

    if [ "$current_url" -lt "$total_urls" ]; then
        delay=$((RANDOM % 240 + 60))
        _dim "waiting ${delay}s before next download..."
        sleep $delay
    fi

done < "$URL_FILE"

_ok "All downloads completed"
