#!/bin/bash
# download-urls — batch download URLs with yt-dlp

usage() {
    echo "Usage: download-urls <urls.txt> [username] [password]"
    echo ""
    echo "Download each URL in the file using yt-dlp, with random"
    echo "delays (1-5 min) between downloads."
    echo ""
    echo "Example: download-urls playlist.txt"
    echo "         download-urls list.txt user pass123"
}

[[ "$1" == "-h" || "$1" == "--help" ]] && { usage; exit 0; }

if [ $# -lt 1 ]; then
    usage
    exit 1
fi

URL_FILE="$1"
USERNAME="$2"
PASSWORD="$3"

if [ ! -f "$URL_FILE" ]; then
    echo "Error: File '$URL_FILE' not found!" >&2
    exit 1
fi

if ! command -v yt-dlp &>/dev/null; then
    echo "Error: yt-dlp is not installed." >&2
    exit 1
fi

echo "Starting download process using URLs from $URL_FILE"
echo "Press Ctrl+C to stop the process at any time"

total_urls=$(grep -c -v "^\s*$" "$URL_FILE")
current_url=0

while IFS= read -r url || [ -n "$url" ]; do
    [ -z "$url" ] && continue
    ((current_url++))
    url=$(echo "$url" | xargs)

    echo "$(date '+%Y-%m-%d %H:%M:%S') - Processing URL ($current_url/$total_urls): $url"

    if [ -n "$USERNAME" ] && [ -n "$PASSWORD" ]; then
        yt-dlp --username "$USERNAME" --password "$PASSWORD" "$url"
    else
        yt-dlp "$url"
    fi

    if [ "$current_url" -lt "$total_urls" ]; then
        delay=$((RANDOM % 240 + 60))
        echo "$(date '+%Y-%m-%d %H:%M:%S') - Done. Waiting $((delay / 60))m $((delay % 60))s..."
        sleep $delay
    fi

done < "$URL_FILE"

echo "$(date '+%Y-%m-%d %H:%M:%S') - All downloads completed!"
