#!/bin/bash
# vid2gif — convert a video file to a GIF

usage() {
    echo "Usage: vid2gif [-s <scale>] <input> <output>"
    echo ""
    echo "Convert a video to GIF using ffmpeg."
    echo ""
    echo "Options:"
    echo "  -s <width>   Resize to <width> pixels wide (default: 480)"
    echo ""
    echo "Example: vid2gif -s 640 input.mp4 output.gif"
}

scale="480"

while getopts "s:h" opt; do
    case $opt in
        s) scale=$OPTARG ;;
        h) usage; exit 0 ;;
        \?) usage; exit 1 ;;
    esac
done

shift $((OPTIND - 1))

[[ "$1" == "--help" ]] && { usage; exit 0; }

if ! command -v ffmpeg &>/dev/null; then
    echo "Error: ffmpeg is not installed." >&2
    exit 1
fi

if [ $# -lt 2 ]; then
    usage
    exit 1
fi

input=$1
output=$2

if [ ! -f "$input" ]; then
    echo "Not found: $input" >&2
    exit 1
fi

if [ -f "$output" ]; then
    echo "Already exists: $output" >&2
    exit 1
fi

ffmpeg -i "$input" -vf "fps=10,scale=$scale:-1:flags=lanczos,split[s0][s1];[s0]palettegen[p];[s1][p]paletteuse" -loop 0 "$output"
