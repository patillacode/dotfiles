#!/bin/bash

# Image Converter Script
# Uses macOS's built-in sips command for image format conversion and transformation
# Supports batch processing and interactive mode

set -euo pipefail

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Print colored output
print_color() {
    local color=$1
    local message=$2
    echo -e "${color}${message}${NC}"
}

# Print usage information
usage() {
    echo -e "${BLUE}╭─────────────────────────────────────────────────────────────────────────────╮${NC}"
    echo -e "${BLUE}│                          ${GREEN}🖼️  IMAGE CONVERTER${BLUE}                                │${NC}"
    echo -e "${BLUE}│                 Transform and convert image formats using sips              │${NC}"
    echo -e "${BLUE}╰─────────────────────────────────────────────────────────────────────────────╯${NC}"
    echo ""
    echo -e "${YELLOW}USAGE:${NC}"
    echo -e "  ${GREEN}$0${NC} ${BLUE}[OPTIONS]${NC} ${YELLOW}[INPUT_FILE]${NC} ${YELLOW}[OUTPUT_FILE]${NC}"
    echo ""
    echo -e "${YELLOW}OPTIONS:${NC}"
    echo -e "  ${GREEN}-f, --format FORMAT${NC}     Output format ${RED}(jpeg, png, gif, bmp, tiff, webp)${NC}"
    echo -e "  ${GREEN}-q, --quality QUALITY${NC}   JPEG quality ${RED}(1-100, default: 85)${NC}"
    echo -e "  ${GREEN}-w, --width WIDTH${NC}       Resize to width ${RED}(pixels)${NC}"
    echo -e "  ${GREEN}-h, --height HEIGHT${NC}     Resize to height ${RED}(pixels)${NC}"
    echo -e "  ${GREEN}-r, --rotate DEGREES${NC}    Rotate image ${RED}(90, 180, 270, or any angle)${NC}"
    echo -e "  ${GREEN}-b, --batch${NC}             Batch mode - process all images in directory"
    echo -e "  ${GREEN}-i, --interactive${NC}       Interactive mode"
    echo -e "  ${GREEN}--help${NC}                  Show this help message"
    echo ""
    echo -e "${YELLOW}EXAMPLES:${NC}"
    echo -e "  ${BLUE}# Convert single file${NC}"
    echo -e "  ${GREEN}$0${NC} input.webp output.jpg"
    echo -e "  ${GREEN}$0${NC} ${RED}-f png -q 90${NC} input.jpg output.png"
    echo ""
    echo -e "  ${BLUE}# Resize and convert${NC}"
    echo -e "  ${GREEN}$0${NC} ${RED}-f jpeg -w 800 -h 600${NC} input.png output.jpg"
    echo ""
    echo -e "  ${BLUE}# Rotate and convert${NC}"
    echo -e "  ${GREEN}$0${NC} ${RED}-f png -r 90${NC} input.jpg output.png"
    echo ""
    echo -e "  ${BLUE}# Interactive mode${NC}"
    echo -e "  ${GREEN}$0${NC} ${RED}-i${NC}"
    echo ""
    echo -e "  ${BLUE}# Batch convert all images to JPEG${NC}"
    echo -e "  ${GREEN}$0${NC} ${RED}-b -f jpeg${NC}"
    echo ""
    echo -e "${YELLOW}SUPPORTED FORMATS:${NC}"
    echo -e "  ${GREEN}Input:${NC}  ${RED}JPEG, PNG, GIF, BMP, TIFF, WEBP, HEIC${NC}"
    echo -e "  ${GREEN}Output:${NC} ${RED}JPEG, PNG, GIF, BMP, TIFF, WEBP${NC}"
    echo ""
}

# Check if sips is available
check_sips() {
    if ! command -v sips &> /dev/null; then
        print_color $RED "Error: sips command not found. This script requires macOS."
        exit 1
    fi
}

# Get supported formats
get_supported_formats() {
    echo "jpeg png gif bmp tiff webp"
}

# Validate format
validate_format() {
    local format=$1
    local supported_formats=$(get_supported_formats)

    for fmt in $supported_formats; do
        if [[ "$format" == "$fmt" ]]; then
            return 0
        fi
    done

    print_color $RED "Error: Unsupported format '$format'"
    print_color $YELLOW "Supported formats: $supported_formats"
    return 1
}

# Get file extension from format
get_extension() {
    local format=$1
    case $format in
        jpeg) echo "jpg" ;;
        *) echo "$format" ;;
    esac
}

# Build sips command
build_sips_command() {
    local input_file=$1
    local output_file=$2
    local cmd="sips"

    # Add format conversion
    if [[ -n "${OUTPUT_FORMAT:-}" ]]; then
        cmd="$cmd -s format $OUTPUT_FORMAT"
    fi

    # Add quality setting (for JPEG)
    if [[ -n "${QUALITY:-}" ]] && [[ "${OUTPUT_FORMAT:-}" == "jpeg" ]]; then
        cmd="$cmd -s formatOptions $QUALITY"
    fi

    # Add width/height resizing
    if [[ -n "${WIDTH:-}" ]] && [[ -n "${HEIGHT:-}" ]]; then
        cmd="$cmd -z $HEIGHT $WIDTH"
    elif [[ -n "${WIDTH:-}" ]]; then
        cmd="$cmd -Z $WIDTH"
    elif [[ -n "${HEIGHT:-}" ]]; then
        cmd="$cmd -Z $HEIGHT"
    fi

    # Add rotation
    if [[ -n "${ROTATION:-}" ]]; then
        cmd="$cmd -r $ROTATION"
    fi

    # Add input and output
    cmd="$cmd \"$input_file\" --out \"$output_file\""

    echo "$cmd"
}

# Convert single file
convert_file() {
    local input_file=$1
    local output_file=$2

    if [[ ! -f "$input_file" ]]; then
        print_color $RED "Error: Input file '$input_file' not found"
        return 1
    fi

    # Create output directory if needed
    local output_dir=$(dirname "$output_file")
    if [[ "$output_dir" != "." ]] && [[ ! -d "$output_dir" ]]; then
        mkdir -p "$output_dir"
    fi

    # Build and execute sips command
    local sips_cmd=$(build_sips_command "$input_file" "$output_file")
    print_color $BLUE "Executing: $sips_cmd"

    if eval $sips_cmd > /dev/null 2>&1; then
        print_color $GREEN "✓ Converted: $input_file → $output_file"

        # Show file sizes
        local input_size=$(stat -f%z "$input_file" 2>/dev/null || echo "0")
        local output_size=$(stat -f%z "$output_file" 2>/dev/null || echo "0")
        local input_size_mb=$(echo "scale=2; $input_size/1024/1024" | bc 2>/dev/null || echo "0")
        local output_size_mb=$(echo "scale=2; $output_size/1024/1024" | bc 2>/dev/null || echo "0")

        if command -v bc &> /dev/null; then
            print_color $YELLOW "  Input: ${input_size_mb}MB → Output: ${output_size_mb}MB"
        fi
        return 0
    else
        print_color $RED "✗ Failed to convert: $input_file"
        return 1
    fi
}

# Interactive mode
interactive_mode() {
    print_color $BLUE "=== Interactive Image Converter ==="
    echo

    # Get input file
    while true; do
        read -p "Enter input file path (or 'quit' to exit): " input_file
        if [[ "$input_file" == "quit" ]]; then
            exit 0
        fi
        if [[ -f "$input_file" ]]; then
            break
        else
            print_color $RED "File not found. Please try again."
        fi
    done

    # Get output format
    local supported_formats=$(get_supported_formats)
    print_color $YELLOW "Supported formats: $supported_formats"
    while true; do
        read -p "Enter output format (default: jpeg): " format
        format=${format:-jpeg}
        if validate_format "$format"; then
            OUTPUT_FORMAT=$format
            break
        fi
    done

    # Get output filename
    local extension=$(get_extension "$OUTPUT_FORMAT")
    local default_output="${input_file%.*}.$extension"
    read -p "Enter output file path (default: $default_output): " output_file
    output_file=${output_file:-$default_output}

    # Optional settings
    if [[ "$OUTPUT_FORMAT" == "jpeg" ]]; then
        read -p "JPEG quality (1-100, default: 85): " quality
        quality=${quality:-85}
        if [[ "$quality" =~ ^[0-9]+$ ]] && [[ "$quality" -ge 1 ]] && [[ "$quality" -le 100 ]]; then
            QUALITY=$quality
        fi
    fi

    read -p "Resize width (pixels, optional): " width
    if [[ "$width" =~ ^[0-9]+$ ]]; then
        WIDTH=$width
    fi

    read -p "Resize height (pixels, optional): " height
    if [[ "$height" =~ ^[0-9]+$ ]]; then
        HEIGHT=$height
    fi

    read -p "Rotation angle (degrees, optional): " rotation
    if [[ "$rotation" =~ ^-?[0-9]+$ ]]; then
        ROTATION=$rotation
    fi

    # Convert
    echo
    print_color $BLUE "Converting..."
    convert_file "$input_file" "$output_file"
}

# Batch mode
batch_mode() {
    if [[ -z "${OUTPUT_FORMAT:-}" ]]; then
        print_color $RED "Error: Output format required for batch mode (-f/--format)"
        exit 1
    fi

    local extension=$(get_extension "$OUTPUT_FORMAT")
    local count=0
    local success=0

    print_color $BLUE "=== Batch Mode: Converting to $OUTPUT_FORMAT ==="

    # Find all image files
    shopt -s nullglob
    for file in *.jpg *.jpeg *.png *.gif *.bmp *.tiff *.webp *.heic *.HEIC; do
        if [[ -f "$file" ]]; then
            local output_file="converted_${file%.*}.$extension"

            # Skip if already in target format
            if [[ "${file##*.}" == "$extension" ]] || [[ "${file##*.}" == "$OUTPUT_FORMAT" ]]; then
                print_color $YELLOW "⚠ Skipping $file (already in $OUTPUT_FORMAT format)"
                continue
            fi

            ((count++))
            if convert_file "$file" "$output_file"; then
                ((success++))
            fi
        fi
    done
    shopt -u nullglob

    echo
    print_color $GREEN "Batch conversion complete: $success/$count files converted successfully"
}

# Main script
main() {
    check_sips

    # Default values
    OUTPUT_FORMAT=""
    QUALITY=""
    WIDTH=""
    HEIGHT=""
    ROTATION=""
    INTERACTIVE=false
    BATCH=false

    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            -f|--format)
                OUTPUT_FORMAT="$2"
                if ! validate_format "$OUTPUT_FORMAT"; then
                    exit 1
                fi
                shift 2
                ;;
            -q|--quality)
                QUALITY="$2"
                if ! [[ "$QUALITY" =~ ^[0-9]+$ ]] || [[ "$QUALITY" -lt 1 ]] || [[ "$QUALITY" -gt 100 ]]; then
                    print_color $RED "Error: Quality must be between 1-100"
                    exit 1
                fi
                shift 2
                ;;
            -w|--width)
                WIDTH="$2"
                if ! [[ "$WIDTH" =~ ^[0-9]+$ ]]; then
                    print_color $RED "Error: Width must be a positive integer"
                    exit 1
                fi
                shift 2
                ;;
            -h|--height)
                HEIGHT="$2"
                if ! [[ "$HEIGHT" =~ ^[0-9]+$ ]]; then
                    print_color $RED "Error: Height must be a positive integer"
                    exit 1
                fi
                shift 2
                ;;
            -r|--rotate)
                ROTATION="$2"
                if ! [[ "$ROTATION" =~ ^-?[0-9]+$ ]]; then
                    print_color $RED "Error: Rotation must be an integer (degrees)"
                    exit 1
                fi
                shift 2
                ;;
            -i|--interactive)
                INTERACTIVE=true
                shift
                ;;
            -b|--batch)
                BATCH=true
                shift
                ;;
            --help)
                usage
                exit 0
                ;;
            -*)
                print_color $RED "Unknown option: $1"
                usage
                exit 1
                ;;
            *)
                break
                ;;
        esac
    done

    # Handle different modes
    if [[ "$INTERACTIVE" == true ]]; then
        interactive_mode
    elif [[ "$BATCH" == true ]]; then
        batch_mode
    else
        # Single file mode
        if [[ $# -lt 1 ]]; then
            print_color $RED "Error: Input file required"
            usage
            exit 1
        fi

        local input_file=$1
        local output_file=${2:-}

        # Auto-generate output filename if not provided
        if [[ -z "$output_file" ]]; then
            if [[ -n "$OUTPUT_FORMAT" ]]; then
                local extension=$(get_extension "$OUTPUT_FORMAT")
                output_file="${input_file%.*}.$extension"
            else
                print_color $RED "Error: Output file or format must be specified"
                usage
                exit 1
            fi
        fi

        # Try to detect format from output filename if not specified
        if [[ -z "$OUTPUT_FORMAT" ]]; then
            local ext="${output_file##*.}"
            case "${ext,,}" in
                jpg) OUTPUT_FORMAT="jpeg" ;;
                jpeg|png|gif|bmp|tiff|webp) OUTPUT_FORMAT="${ext,,}" ;;
                *)
                    print_color $RED "Error: Cannot detect output format from filename"
                    usage
                    exit 1
                    ;;
            esac
        fi

        convert_file "$input_file" "$output_file"
    fi
}

# Run main function with all arguments
main "$@"
