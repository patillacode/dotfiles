#!/bin/bash
# img-convert — convert image formats using sips (macOS)

set -euo pipefail

source "${HOME}/.local/lib/tui.sh" 2>/dev/null || { echo "tui.sh not found — run: chezmoi apply" >&2; exit 1; }

# Print usage information
usage() {
    _header "img-convert — convert image formats using sips"
    echo ""
    _section "USAGE:"
    echo "  $0 [OPTIONS] [INPUT_FILE] [OUTPUT_FILE]"
    echo ""
    _section "OPTIONS:"
    _item "-f, --format FORMAT"   "Output format (jpeg, png, gif, bmp, tiff, webp)"
    _item "-q, --quality QUALITY" "JPEG quality (1-100, default: 85)"
    _item "-w, --width WIDTH"     "Resize to width (pixels)"
    _item "-h, --height HEIGHT"   "Resize to height (pixels)"
    _item "-r, --rotate DEGREES"  "Rotate image (90, 180, 270, or any angle)"
    _item "-b, --batch"           "Batch mode - process all images in directory"
    _item "-i, --interactive"     "Interactive mode"
    _item "--help"                "Show this help message"
    echo ""
    _section "EXAMPLES:"
    _dim "# Convert single file"
    echo "  $0 input.webp output.jpg"
    echo "  $0 -f png -q 90 input.jpg output.png"
    echo ""
    _dim "# Resize and convert"
    echo "  $0 -f jpeg -w 800 -h 600 input.png output.jpg"
    echo ""
    _dim "# Rotate and convert"
    echo "  $0 -f png -r 90 input.jpg output.png"
    echo ""
    _dim "# Interactive mode"
    echo "  $0 -i"
    echo ""
    _dim "# Batch convert all images to JPEG"
    echo "  $0 -b -f jpeg"
    echo ""
    _section "SUPPORTED FORMATS:"
    _item "Input:"  "JPEG, PNG, GIF, BMP, TIFF, WEBP, HEIC"
    _item "Output:" "JPEG, PNG, GIF, BMP, TIFF, WEBP"
    echo ""
}

# Check if sips is available
check_sips() {
    if ! command -v sips &> /dev/null; then
        _fail "Error: sips command not found. This script requires macOS."
        exit 1
    fi
}

# Get supported formats
get_supported_formats() {
    echo "jpeg png gif bmp tiff webp"
}

# Validate format
validate_format() {
    local format=$1
    local supported_formats=$(get_supported_formats)

    for fmt in $supported_formats; do
        if [[ "$format" == "$fmt" ]]; then
            return 0
        fi
    done

    _fail "Error: Unsupported format '$format'"
    _warn "Supported formats: $supported_formats"
    return 1
}

# Get file extension from format
get_extension() {
    local format=$1
    case $format in
        jpeg) echo "jpg" ;;
        *) echo "$format" ;;
    esac
}

# Build sips command
build_sips_command() {
    local input_file=$1
    local output_file=$2
    local cmd="sips"

    # Add format conversion
    if [[ -n "${OUTPUT_FORMAT:-}" ]]; then
        cmd="$cmd -s format $OUTPUT_FORMAT"
    fi

    # Add quality setting (for JPEG)
    if [[ -n "${QUALITY:-}" ]] && [[ "${OUTPUT_FORMAT:-}" == "jpeg" ]]; then
        cmd="$cmd -s formatOptions $QUALITY"
    fi

    # Add width/height resizing
    if [[ -n "${WIDTH:-}" ]] && [[ -n "${HEIGHT:-}" ]]; then
        cmd="$cmd -z $HEIGHT $WIDTH"
    elif [[ -n "${WIDTH:-}" ]]; then
        cmd="$cmd -Z $WIDTH"
    elif [[ -n "${HEIGHT:-}" ]]; then
        cmd="$cmd -Z $HEIGHT"
    fi

    # Add rotation
    if [[ -n "${ROTATION:-}" ]]; then
        cmd="$cmd -r $ROTATION"
    fi

    # Add input and output
    cmd="$cmd \"$input_file\" --out \"$output_file\""

    echo "$cmd"
}

# Convert single file
convert_file() {
    local input_file=$1
    local output_file=$2

    if [[ ! -f "$input_file" ]]; then
        _fail "Error: Input file '$input_file' not found"
        return 1
    fi

    # Create output directory if needed
    local output_dir=$(dirname "$output_file")
    if [[ "$output_dir" != "." ]] && [[ ! -d "$output_dir" ]]; then
        mkdir -p "$output_dir"
    fi

    # Build and execute sips command
    local sips_cmd=$(build_sips_command "$input_file" "$output_file")
    _dim "Executing: $sips_cmd"

    if eval $sips_cmd > /dev/null 2>&1; then
        _ok "Converted: $input_file → $output_file"

        # Show file sizes
        local input_size=$(stat -f%z "$input_file" 2>/dev/null || echo "0")
        local output_size=$(stat -f%z "$output_file" 2>/dev/null || echo "0")
        local input_size_mb=$(echo "scale=2; $input_size/1024/1024" | bc 2>/dev/null || echo "0")
        local output_size_mb=$(echo "scale=2; $output_size/1024/1024" | bc 2>/dev/null || echo "0")

        if command -v bc &> /dev/null; then
            _warn "Input: ${input_size_mb}MB → Output: ${output_size_mb}MB"
        fi
        return 0
    else
        _fail "Failed to convert: $input_file"
        return 1
    fi
}

# Interactive mode
interactive_mode() {
    _require_gum
    _header "Interactive Image Converter"

    # Get input file
    input_file=$(gum file --header="Select input image")

    # Get output format
    OUTPUT_FORMAT=$(_menu "Output format" jpeg png gif bmp tiff webp)

    # Get output filename
    local extension=$(get_extension "$OUTPUT_FORMAT")
    local default_output="${input_file%.*}.$extension"
    output_file=$(_input "Output filename" "$default_output")
    output_file=${output_file:-$default_output}

    # Optional settings
    if [[ "$OUTPUT_FORMAT" == "jpeg" ]]; then
        local quality
        quality=$(_input "JPEG quality (1-100)" "85")
        quality=${quality:-85}
        if [[ "$quality" =~ ^[0-9]+$ ]] && [[ "$quality" -ge 1 ]] && [[ "$quality" -le 100 ]]; then
            QUALITY=$quality
        fi
    fi

    local width
    width=$(_input "Resize width (pixels, optional — leave blank to skip)" "")
    if [[ "$width" =~ ^[0-9]+$ ]]; then
        WIDTH=$width
    fi

    local height
    height=$(_input "Resize height (pixels, optional — leave blank to skip)" "")
    if [[ "$height" =~ ^[0-9]+$ ]]; then
        HEIGHT=$height
    fi

    local rotation
    rotation=$(_input "Rotation angle (degrees, optional — leave blank to skip)" "")
    if [[ "$rotation" =~ ^-?[0-9]+$ ]]; then
        ROTATION=$rotation
    fi

    # Convert
    echo
    _dim "Converting..."
    convert_file "$input_file" "$output_file"
}

# Batch mode
batch_mode() {
    if [[ -z "${OUTPUT_FORMAT:-}" ]]; then
        _fail "Error: Output format required for batch mode (-f/--format)"
        exit 1
    fi

    local extension=$(get_extension "$OUTPUT_FORMAT")
    local count=0
    local success=0

    _header "Batch mode: converting to $OUTPUT_FORMAT"

    # Find all image files
    shopt -s nullglob
    for file in *.jpg *.jpeg *.png *.gif *.bmp *.tiff *.webp *.heic *.HEIC; do
        if [[ -f "$file" ]]; then
            local output_file="converted_${file%.*}.$extension"

            # Skip if already in target format
            if [[ "${file##*.}" == "$extension" ]] || [[ "${file##*.}" == "$OUTPUT_FORMAT" ]]; then
                _warn "Skipping $file (already in $OUTPUT_FORMAT format)"
                continue
            fi

            ((count++))
            if convert_file "$file" "$output_file"; then
                ((success++))
            fi
        fi
    done
    shopt -u nullglob

    echo
    _ok "Batch conversion complete: $success/$count files converted successfully"
}

# Main script
main() {
    check_sips

    # Default values
    OUTPUT_FORMAT=""
    QUALITY=""
    WIDTH=""
    HEIGHT=""
    ROTATION=""
    INTERACTIVE=false
    BATCH=false

    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            -f|--format)
                OUTPUT_FORMAT="$2"
                if ! validate_format "$OUTPUT_FORMAT"; then
                    exit 1
                fi
                shift 2
                ;;
            -q|--quality)
                QUALITY="$2"
                if ! [[ "$QUALITY" =~ ^[0-9]+$ ]] || [[ "$QUALITY" -lt 1 ]] || [[ "$QUALITY" -gt 100 ]]; then
                    _fail "Error: Quality must be between 1-100"
                    exit 1
                fi
                shift 2
                ;;
            -w|--width)
                WIDTH="$2"
                if ! [[ "$WIDTH" =~ ^[0-9]+$ ]]; then
                    _fail "Error: Width must be a positive integer"
                    exit 1
                fi
                shift 2
                ;;
            -h|--height)
                HEIGHT="$2"
                if ! [[ "$HEIGHT" =~ ^[0-9]+$ ]]; then
                    _fail "Error: Height must be a positive integer"
                    exit 1
                fi
                shift 2
                ;;
            -r|--rotate)
                ROTATION="$2"
                if ! [[ "$ROTATION" =~ ^-?[0-9]+$ ]]; then
                    _fail "Error: Rotation must be an integer (degrees)"
                    exit 1
                fi
                shift 2
                ;;
            -i|--interactive)
                INTERACTIVE=true
                shift
                ;;
            -b|--batch)
                BATCH=true
                shift
                ;;
            --help)
                usage
                exit 0
                ;;
            -*)
                _fail "Unknown option: $1"
                usage
                exit 1
                ;;
            *)
                break
                ;;
        esac
    done

    # Handle different modes
    if [[ "$INTERACTIVE" == true ]]; then
        interactive_mode
    elif [[ "$BATCH" == true ]]; then
        batch_mode
    else
        # Single file mode
        if [[ $# -lt 1 ]]; then
            _fail "Error: Input file required"
            usage
            exit 1
        fi

        local input_file=$1
        local output_file=${2:-}

        # Auto-generate output filename if not provided
        if [[ -z "$output_file" ]]; then
            if [[ -n "$OUTPUT_FORMAT" ]]; then
                local extension=$(get_extension "$OUTPUT_FORMAT")
                output_file="${input_file%.*}.$extension"
            else
                _fail "Error: Output file or format must be specified"
                usage
                exit 1
            fi
        fi

        # Try to detect format from output filename if not specified
        if [[ -z "$OUTPUT_FORMAT" ]]; then
            local ext="${output_file##*.}"
            case "${ext,,}" in
                jpg) OUTPUT_FORMAT="jpeg" ;;
                jpeg|png|gif|bmp|tiff|webp) OUTPUT_FORMAT="${ext,,}" ;;
                *)
                    _fail "Error: Cannot detect output format from filename"
                    usage
                    exit 1
                    ;;
            esac
        fi

        convert_file "$input_file" "$output_file"
    fi
}

# Run main function with all arguments
main "$@"
