#!/bin/bash
# screen-cap — record your screen (macOS)
################################################################################
# This script allows you to capture your screen on Linux or macOS systems using
# the appropriate tools available on each platform. On Linux, it uses 'slop'
# and 'ffmpeg', while on macOS, it utilizes 'screencapture'. The script prompts
# you to select a desktop area for recording and saves the recording as an MP4/MOV
# file with customizable video quality.
#
# Usage: screen-cap [options] <output.mp4>
#
# Options:
#   -v, --version        Display script version
#   -h, --help           Display this help message
#   -q, --quality <num>  (only for Linux) Specify the video quality in the range
#                        0-51 (best/worst) (default: 28)
#
# Requirements:
#   - For Linux: slop, ffmpeg
#   - For macOS: screencapture
################################################################################

source "${HOME}/.local/lib/tui.sh" 2>/dev/null || { echo "tui.sh not found — run: chezmoi apply" >&2; exit 1; }

# Function to display script version
show_version() {
  echo "screen-cap - capture your screen - 0.0.1"
}

# Function to display script usage
show_usage() {
  echo "Usage: $0 [options] <output.mp4>"
  echo "Options:"
  echo "  -v, --version        Display script version"
  echo "  -h, --help           Display this help message"
  echo "  -q, --quality <num>  (only for Linux) Specify the video quality in range 0–51(best/worst)(default: 28)"
}

# Function to check if the required command exists
check_command() {
  if ! command -v $1 &> /dev/null
  then
    _fail "$1 not found — please install $1"
    exit 1
  fi
}

# Function to check if an output filename was provided
check_filename() {
  if [ -z "$1" ]; then
    echo "Usage: $0 [options] <output.mp4>"
    exit 1
  fi
}

run_checks() {
  # Check the operating system
  if [[ "$OSTYPE" == "linux-gnu"* ]]; then
    check_filename "$1"
    filename="$1"
    system="linux"
    _item "system" "linux (slop + ffmpeg)"
    check_command "ffmpeg"
    check_command "slop"
  elif [[ "$OSTYPE" == "darwin"* ]]; then
    system="macos"
    commandtool="screencapture"
    _item "system" "macOS (screencapture)"
    check_command "screencapture"
  else
    _fail "Unsupported operating system"
    exit 1
  fi
  handle_options "$@"
}

# Function to start the recording
start_recording() {
  if [[ $system == "linux" ]]; then
    _ok "Recording started — press q to stop"
    ffmpeg -loglevel quiet \
    -f x11grab \
    -s ${width}x${height} \
    -i ${DISPLAY}+$x,$y \
    -f alsa -i pulse \
    -c:v libx264 \
    -crf $quality \
    -preset ultrafast \
    -tune zerolatency \
    -pix_fmt yuv420p \
    -f mp4 \
    $filename
  else
    screencapture -vks -t "$macos_format" "$macos_output"
  fi
}

# Function to handle command line options
handle_options() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -v|--version)
        show_version
        exit 0
        ;;
      -h|--help)
        show_usage
        exit 0
        ;;
      -q|--quality)
        shift
        quality="$1"
        _item "quality" "$quality"
        ;;
      *)
        break
        ;;
    esac
    shift
  done
}

# Default quality value
quality=28

run_checks "$@"

if [[ "$system" == "linux" ]]; then
  coords=$(slop -f "%x %y %w %h")
  x=$(echo $coords | awk '{print $1}')
  y=$(echo $coords | awk '{print $2}')
  width=$(echo $coords | awk '{print $3}')
  height=$(echo $coords | awk '{print $4}')
  width=$((width / 2 * 2))
  height=$((height / 2 * 2))
  start_recording
  _ok "Recording stopped"
elif [[ "$system" == "macos" ]]; then
  # Determine output file: use provided arg or prompt interactively
  # Find the non-option argument (output filename) from original args
  macos_output=""
  for arg in "$@"; do
    case "$arg" in
      -v|--version|-h|--help|-q|--quality) ;;
      *) macos_output="$arg"; break ;;
    esac
  done

  if [[ -z "$macos_output" ]]; then
    _require_gum
    format=$(_menu "Select output format" "MOV" "MP4")
    macos_format="${format,,}"
    macos_output=$(_input "Output filename" "recording.${macos_format}")
  else
    # Infer format from provided filename extension
    ext="${macos_output##*.}"
    macos_format="${ext,,}"
    [[ "$macos_format" != "mov" && "$macos_format" != "mp4" ]] && macos_format="mov"
  fi

  start_recording
  _ok "Recording saved to desktop"
fi
