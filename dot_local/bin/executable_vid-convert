#!/bin/bash
# vid-convert — convert video between formats (e.g. mkv to mp4)

usage() {
    echo "Usage: vid-convert <input> <output>"
    echo ""
    echo "Convert a video file to another format. Tries stream copy first,"
    echo "falls back to re-encoding if needed."
    echo ""
    echo "Example: vid-convert movie.mkv movie.mp4"
}

[[ "$1" == "-h" || "$1" == "--help" ]] && { usage; exit 0; }

if [ $# -lt 2 ]; then
    usage
    exit 1
fi

if ! command -v ffmpeg &>/dev/null; then
    echo "Error: ffmpeg is not installed." >&2
    exit 1
fi

input="$1"
output="$2"

if [ ! -f "$input" ]; then
    echo "Not found: $input" >&2
    exit 1
fi

if [ -f "$output" ]; then
    echo "Already exists: $output" >&2
    exit 1
fi

ffmpeg -i "$input" -c copy "$output" || ffmpeg -i "$input" "$output"
echo "Saved to: $output"
