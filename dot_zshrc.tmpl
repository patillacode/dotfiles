# .zshrc — managed by chezmoi
# Machine: {{ .machine_name }} | Profile: {{ last .profiles }} | Shell: {{ .shell }}

#############
# oh-my-zsh #
#############

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="bars"

SHARE_HISTORY="false"
setopt no_share_history

# Disable default virtualenv prompt (customized in bars.zsh-theme)
VIRTUAL_ENV_DISABLE_PROMPT="true"

plugins=(zsh-syntax-highlighting)
source $ZSH/oh-my-zsh.sh

###########
# SECRETS #
###########

# Local env overrides (not managed by chezmoi, machine-specific)
[[ -f "$HOME/.env" ]] && source "$HOME/.env"

###########
# ALIASES #
###########

{{- $activeProfile := last .profiles }}
{{- $aliases := index .profile_aliases $activeProfile }}
{{ range $aliases }}
source "$HOME/.alias/{{ . }}.sh"
{{- end }}

{{ if eq .machine_name "bars" -}}
# bars-specific: telegram notifier
[[ -f "$HOME/projects/bash/telegram/guardia.sh" ]] && source "$HOME/projects/bash/telegram/guardia.sh"
{{ end -}}

{{ if eq .machine_name "nordhealth" -}}
# nordhealth-specific: work tool paths
export PATH="/opt/homebrew/opt/node@20/bin:$PATH"
export PATH="/opt/homebrew/opt/mysql@8.0/bin:$PATH"
{{ end -}}

###########
# Exports #
###########

export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export LC_CTYPE=en_US.UTF-8

export HOMEBREW_NO_AUTO_UPDATE=1

# https://github.com/junegunn/fzf/blob/master/ADVANCED.md#color-themes
export FZF_DEFAULT_OPTS='--color=bg+:#293739,bg:#1B1D1E,border:#808080,spinner:#E6DB74,hl:#7E8E91,fg:#F8F8F2,header:#7E8E91,info:#A6E22E,pointer:#A6E22E,marker:#F92672,fg+:#F8F8F2,prompt:#F92672,hl+:#F92672'
source <(fzf --zsh)

# go
export PATH="$HOME/go/bin:$PATH"

# local bin (uv tools, pipx legacy)
export PATH="$PATH:$HOME/.local/bin"

##########
# Prompt #
##########

# Starship — theme selectable via chezmoi data
export STARSHIP_CONFIG="$HOME/.config/starship/{{ .starship.theme }}.toml"
eval "$(starship init {{ .shell }})"

eval "$(atuin init {{ .shell }})"

# Uncomment to profile zsh startup time (also uncomment zmodload at top):
# zprof
