#!/bin/bash
# run_onchange_update-hosts.sh — append custom /etc/hosts entries
# Reruns when this script changes
# hash: {{ include ".chezmoiscripts/run_onchange_update-hosts.sh.tmpl" | sha256sum }}

set -e

MARKER="# chezmoi-managed entries"

# Remove previously managed block if present (idempotent)
if grep -q "$MARKER" /etc/hosts; then
    sudo sed -i.bak "/$MARKER/,/# end chezmoi-managed entries/d" /etc/hosts
fi

# Append custom entries for this machine
sudo tee -a /etc/hosts > /dev/null <<'EOF'
# chezmoi-managed entries — do not edit manually
{{ if eq .machine_name "bars" -}}
# bars-specific hosts (add yours here)
{{ else if eq .machine_name "archbook" -}}
# archbook-specific hosts (add yours here)
{{ else if eq .machine_name "totoro" -}}
# totoro-specific hosts (add yours here)
{{ else if eq .machine_name "tops-staging" -}}
# tops-staging-specific hosts (add yours here)
{{ else if eq .machine_name "ushuaia" -}}
# ushuaia-specific hosts (add yours here)
{{ end -}}
# end chezmoi-managed entries
EOF

echo "/etc/hosts updated for {{ .machine_name }}."
