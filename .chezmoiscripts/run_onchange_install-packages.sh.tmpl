#!/bin/bash
# run_onchange_install-packages.sh — reruns when package list changes
# Package data hash: {{ .trait_packages | toJson | sha256sum }}

set -e

{{- /* ─── Resolve all packages from active traits ────────── */}}
{{- $formulae := list }}
{{- $casks := list }}
{{- $aptPkgs := list }}
{{- range .profiles }}
{{-   $pkgs := index $.trait_packages . | default list }}
{{-   range $pkgs }}
{{-     if kindIs "string" . }}
{{-       $formulae = append $formulae . }}
{{-       $aptPkgs = append $aptPkgs . }}
{{-     else }}
{{-       $name := index . "name" }}
{{-       $type := index . "type" | default "formula" }}
{{-       $aptName := index . "apt" | default $name }}
{{-       if eq $type "cask" }}
{{-         $casks = append $casks $name }}
{{-         if index . "apt" }}{{ $aptPkgs = append $aptPkgs $aptName }}{{ end }}
{{-       else }}
{{-         $formulae = append $formulae $name }}
{{-         $aptPkgs = append $aptPkgs $aptName }}
{{-       end }}
{{-     end }}
{{-   end }}
{{- end }}
{{- $formulae = $formulae | uniq }}
{{- $casks = $casks | uniq }}
{{- $aptPkgs = $aptPkgs | uniq }}

{{ if eq .chezmoi.os "darwin" -}}
# ─── macOS: Homebrew formulae ────────────────────────────────
FORMULAE=(
{{- range $formulae }}
    "{{ . }}"
{{- end }}
)

echo "Installing Homebrew formulae..."
for pkg in "${FORMULAE[@]}"; do
    if ! brew list --formula "$pkg" &>/dev/null; then
        brew install "$pkg"
    fi
done

# ─── macOS: Homebrew casks ───────────────────────────────────
CASKS=(
{{- range $casks }}
    "{{ . }}"
{{- end }}
)

echo "Installing Homebrew casks..."
for cask in "${CASKS[@]}"; do
    if ! brew list --cask "$cask" &>/dev/null; then
        brew install --cask "$cask"
    fi
done

# ─── macOS: Nerd Fonts ───────────────────────────────────────
echo "Installing Nerd Fonts..."
for font in {{ range .nerd_fonts }}"{{ . }}" {{ end }}; do
    if ! brew list --cask "$font" &>/dev/null; then
        brew install --cask "$font"
    fi
done

{{ else if eq .chezmoi.os "linux" -}}
# ─── Linux: apt packages ─────────────────────────────────────

{{- if not .use_homebrew }}
# Base packages — skipped when Homebrew is active (brew provides these instead)
APT_PKGS=(
{{- range $aptPkgs }}
    "{{ . }}"
{{- end }}
{{- range .profiles }}
{{-   $extras := index $.apt_extras . | default list }}
{{-   range $extras }}
    "{{ . }}"
{{-   end }}
{{- end }}
)
echo "Installing apt packages..."
sudo apt-get update -qq
sudo apt-get install -y "${APT_PKGS[@]}"
{{- else }}
echo "Homebrew is active — skipping apt base packages (brew provides these)."
sudo apt-get update -qq
{{- end }}

{{- if .use_homebrew }}
# ─── Linux: Homebrew (optional) ──────────────────────────────
if ! command -v brew &>/dev/null; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# Add brew to PATH for this script session
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv bash)"

BREW_PKGS=(
{{- range $formulae }}
    "{{ . }}"
{{- end }}
)

echo "Installing Homebrew packages on Linux..."
for pkg in "${BREW_PKGS[@]}"; do
    if ! brew list --formula "$pkg" &>/dev/null; then
        brew install "$pkg"
    fi
done
{{- end }}

{{ end -}}

echo "Package installation complete."
