#!/bin/bash
# run_onchange_install-python-tools.sh — reruns when tool list changes
# Tool data hash: {{ .trait_python_tools | toJson | sha256sum }}

set -e

{{- $tools := list }}
{{- range .profiles }}
{{-   $profileTools := index $.trait_python_tools . | default list }}
{{-   range $profileTools }}
{{-     $tools = append $tools . }}
{{-   end }}
{{- end }}

{{ if not $tools -}}
# No Python tools for active traits — nothing to do
exit 0
{{ end -}}

# ─── uv ──────────────────────────────────────────────────────
if ! command -v uv &>/dev/null; then
    echo "Installing uv..."
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="$HOME/.local/bin:$PATH"
fi

# ─── Python tools ────────────────────────────────────────────
TOOLS=(
{{- range $tools }}
    "{{ . }}"
{{- end }}
)

echo "Installing Python tools via uv..."
for tool in "${TOOLS[@]}"; do
    if ! uv tool list 2>/dev/null | grep -q "^$tool "; then
        uv tool install "$tool"
    fi
done

echo "Python tools installation complete."
