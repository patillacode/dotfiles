#!/bin/bash
# run_onchange_install-oh-my-zsh.sh — reruns when plugin list changes
{{ if ne .shell "zsh" -}}
# Shell is {{ .shell }}, not zsh — skipping oh-my-zsh setup
exit 0
{{ end -}}

set -e

# ─── oh-my-zsh ───────────────────────────────────────────────
if [ ! -d "$HOME/.oh-my-zsh" ]; then
    echo "Installing oh-my-zsh..."
    RUNZSH=no CHSH=no sh -c "$(curl -fsSL https://raw.github.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
fi

# ─── plugins ─────────────────────────────────────────────────
ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"

install_plugin() {
    local repo="$1"
    local name
    name="$(basename "$repo")"
    local dest="$ZSH_CUSTOM/plugins/$name"
    if [ ! -d "$dest" ]; then
        echo "Installing oh-my-zsh plugin: $name"
        git clone --depth=1 "$repo" "$dest"
    fi
}

install_plugin "https://github.com/zsh-users/zsh-syntax-highlighting"

echo "oh-my-zsh setup complete."
