# ~/.env — private, managed by chezmoi (never tracked in git)
# Secrets are injected at `chezmoi apply` time from your KeePassXC database.
# The source template contains only template calls — never actual secret values.
#
# To add a new secret:
#   1. Add entry in KeePassXC under group "dotfiles"
#   2. Add a line below: export KEY="{{ keepassxcAttribute "dotfiles/entry-name" "Password" }}"
#   3. Run: chezmoi apply
#
# Required KeePassXC entry: dotfiles/github-pat (Password field = your token)

{{ if .keepassxc.database -}}
export GITHUB_TOKEN="{{ keepassxcAttribute "dotfiles/github-pat" "Password" }}"
{{ else -}}
# KeePassXC database not configured — set keepassxc.database in chezmoi.toml to enable secret injection.
# Run: chezmoi edit-config
{{ end -}}
