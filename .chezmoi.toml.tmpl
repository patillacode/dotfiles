{{- /* ─── Machine identity ─────────────────────────────── */ -}}
{{- $machineName := promptStringOnce . "machine_name" "Machine name (bars/nordhealth/totoro)" "" -}}

{{- /* ─── OS / shell detection ─────────────────────────── */ -}}
{{- $shell := "zsh" -}}
{{- $useHomebrew := true -}}
{{- if eq .chezmoi.os "linux" -}}
{{-   $shell = promptStringOnce . "shell" "Shell (zsh/bash)" "bash" -}}
{{-   $useHomebrew = promptBoolOnce . "use_homebrew" "Install Homebrew on this Linux machine?" false -}}
{{- end -}}

{{- /* ─── Profile selection ──────────────────────────────── */ -}}
{{- /*
     Traits (pick a preset or build your own):
       base       — core CLI tools, all machines
       desktop    — GUI apps (ghostty, raycast, etc.)
       developer  — dev tools (nvim, zed, uv, etc.)
       personal   — entertainment (music, tv, mpv)
       work       — work-specific (nordhealth git)
*/ -}}
{{- $preset := promptStringOnce . "profile_preset" "Profile preset: 1=personal 2=work 3=server 4=server-dev 5=custom" "1" -}}
{{- $profiles := list "base" -}}
{{- if eq $preset "1" -}}
{{-   $profiles = list "base" "desktop" "developer" "personal" -}}
{{- else if eq $preset "2" -}}
{{-   $profiles = list "base" "desktop" "developer" "work" -}}
{{- else if eq $preset "3" -}}
{{-   $profiles = list "base" -}}
{{- else if eq $preset "4" -}}
{{-   $profiles = list "base" "developer" -}}
{{- else if eq $preset "5" -}}
{{-   $hasDesktop := promptBoolOnce . "trait_desktop" "Include desktop trait (GUI apps)?" true -}}
{{-   $hasDeveloper := promptBoolOnce . "trait_developer" "Include developer trait (dev tools)?" true -}}
{{-   $hasPersonal := promptBoolOnce . "trait_personal" "Include personal trait (entertainment)?" false -}}
{{-   $hasWork := promptBoolOnce . "trait_work" "Include work trait?" false -}}
{{-   if $hasDesktop }}{{ $profiles = append $profiles "desktop" }}{{ end -}}
{{-   if $hasDeveloper }}{{ $profiles = append $profiles "developer" }}{{ end -}}
{{-   if $hasPersonal }}{{ $profiles = append $profiles "personal" }}{{ end -}}
{{-   if $hasWork }}{{ $profiles = append $profiles "work" }}{{ end -}}
{{- end -}}

{{- /* ─── Starship theme ──────────────────────────────────── */ -}}
{{- $starshipTheme := promptStringOnce . "starship_theme" "Starship theme (simple/minimal/nord/bars/nordhealth/totoro)" "simple" -}}

{{- /* ─── Git identity ────────────────────────────────────── */ -}}
{{- $gitName := promptStringOnce . "git_name" "Git user name" "PatillaCode" -}}
{{- $gitEmail := promptStringOnce . "git_email" "Git email" "patillacode@gmail.com" -}}

{{- /* ─── KeePassXC ───────────────────────────────────────── */ -}}
{{- $keepassDb := promptStringOnce . "keepassxc_database" "KeePassXC database path (full path to .kdbx)" "" -}}

{{- /* ─── Claude Code ─────────────────────────────────────── */ -}}
{{- $claudeVariant := "none" -}}
{{- if has "developer" $profiles -}}
{{-   $claudeVariant = promptStringOnce . "claude_variant" "Claude Code variant (personal/work/none)" "personal" -}}
{{- end -}}

{{- /* ─── Font ─────────────────────────────────────────────── */ -}}
{{- $fontFamily := promptStringOnce . "font_family" "Font family" "Hack Nerd Font Propo" -}}
{{- $fontSize := promptIntOnce . "font_size" "Font size" 17 -}}

sourceDir = "{{ .chezmoi.homeDir }}/dotfiles"

{{ if $keepassDb -}}
[keepassxc]
    database = {{ $keepassDb | quote }}

{{ end -}}
[data]
    machine_name = {{ $machineName | quote }}
    os = {{ .chezmoi.os | quote }}
    shell = {{ $shell | quote }}
    use_homebrew = {{ $useHomebrew }}
    profiles = {{ $profiles | toJson }}
    exclude_aliases = []
    exclude_configs = []
    include_aliases = []
    include_configs = []

    [data.font]
        family = {{ $fontFamily | quote }}
        size = {{ $fontSize }}

    [data.starship]
        theme = {{ $starshipTheme | quote }}

    [data.git]
        name = {{ $gitName | quote }}
        email = {{ $gitEmail | quote }}

    [data.keepassxc]
        database = {{ $keepassDb | quote }}

    [data.claude]
        variant = {{ $claudeVariant | quote }}
