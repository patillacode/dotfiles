{{- /* ─── Machine identity ─────────────────────────────── */ -}}
{{- $machineName := promptStringOnce . "machine_name" "Machine name" "" -}}

{{- /* ─── OS / shell detection ─────────────────────────── */ -}}
{{- $shell := "zsh" -}}
{{- if eq .chezmoi.os "linux" -}}
{{-   $shell = promptStringOnce . "shell" "Shell (zsh/bash)" "bash" -}}
{{- end -}}

{{- /* ─── Purpose and GUI ──────────────────────────────── */ -}}
{{- $purpose := promptStringOnce . "purpose" "Personal or work machine? (personal/work)" "personal" -}}
{{- $hasGui := promptBoolOnce . "has_gui" "Does this machine have a GUI / screen" true -}}

{{- /* ─── Profile assembly ─────────────────────────────── */ -}}
{{- $profiles := list "base" -}}
{{- if $hasGui }}{{ $profiles = append $profiles "gui" }}{{ end -}}
{{- if eq $purpose "work" }}{{ $profiles = append $profiles "work" }}{{ else }}{{ $profiles = append $profiles "personal" }}{{ end -}}

{{- /* ─── Starship theme ──────────────────────────────────── */ -}}
{{- $starshipTheme := promptStringOnce . "starship_theme" "Starship theme (banana/simple/minimal/nord/totoro)" "banana" -}}

{{- /* ─── Git identity ────────────────────────────────────── */ -}}
{{- $gitName := promptStringOnce . "git_name" "Git user name" "PatillaCode" -}}
{{- $gitEmail := promptStringOnce . "git_email" "Git email" "patillacode@gmail.com" -}}

{{- /* ─── KeePassXC ───────────────────────────────────────── */ -}}
{{- $keepassDb := promptStringOnce . "keepassxc_database" "KeePassXC database path (full path to .kdbx)" "" -}}

{{- /* ─── Font ─────────────────────────────────────────────── */ -}}
{{- $fontFamily := "Hack Nerd Font Propo" -}}
{{- $fontSize := 17 -}}
{{- if $hasGui -}}
{{-   $fontFamily = promptStringOnce . "font_family" "Font family" "Hack Nerd Font Propo" -}}
{{-   $fontSize = promptIntOnce . "font_size" "Font size" 17 -}}
{{- end -}}

sourceDir = "{{ .chezmoi.homeDir }}/dotfiles"

{{ if $keepassDb -}}
[keepassxc]
    database = {{ $keepassDb | quote }}

{{ end -}}
[data]
    machine_name = {{ $machineName | quote }}
    os = {{ .chezmoi.os | quote }}
    shell = {{ $shell | quote }}
    use_homebrew = true
    profiles = {{ $profiles | toJson }}
    exclude_aliases = []
    exclude_configs = []
    include_aliases = []
    include_configs = []

    [data.font]
        family = {{ $fontFamily | quote }}
        size = {{ $fontSize }}

    [data.starship]
        theme = {{ $starshipTheme | quote }}

    [data.git]
        name = {{ $gitName | quote }}
        email = {{ $gitEmail | quote }}

    [data.keepassxc]
        database = {{ $keepassDb | quote }}
